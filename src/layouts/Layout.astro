---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object;
  pageClass?: string;
  sidebar?: boolean;
  keywords?: string;
}

const { title, description, canonical, schema, pageClass = '', sidebar = false, keywords } = Astro.props;
const currentPath = Astro.url.pathname;
const site = 'https://onlineaudiotest.com';
const canonicalURL = canonical || new URL(Astro.url.pathname, site).href;
const ogImage = `${site}/ogImage.png`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="canonical" href={canonicalURL} />
  <meta name="generator" content={Astro.generator} />

  <!-- Primary Meta -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="author" content="OnlineAudioTest.com" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={title} />
  <meta property="og:site_name" content="OnlineAudioTest.com" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@onlineaudiotest" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={title} />

  <!-- Fonts: Geist (Vercel's typeface, open-sourced) + Geist Mono -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400&display=swap" rel="stylesheet" />

  <!-- Schema.org JSON-LD -->
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>
<body class={pageClass}>

  <!-- ───── NAV ───── -->
  <header class="nav" role="banner">
    <div class="nav-inner container">
      <a href="/" class="nav-logo" aria-label="OnlineAudioTest home">
        <img src="/icon.png" width="22" height="22" alt="" aria-hidden="true" />
        <span class="logo-text">onlineaudiotest</span>
      </a>

      <nav class="nav-links" aria-label="Main navigation">
        <a href="/mic-test" class:list={['nav-link', { 'nav-active': currentPath === '/mic-test' }]}>
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <rect x="7" y="2" width="6" height="11" rx="3" stroke="currentColor" stroke-width="1.5"/>
            <path d="M4 10a6 6 0 0012 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="10" y1="16" x2="10" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="7" y1="19" x2="13" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="nav-link-text">Mic Test</span>
        </a>
        <a href="/speaker-test" class:list={['nav-link', { 'nav-active': currentPath === '/speaker-test' }]}>
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 7h3.5L11 3v14l-4.5-4H3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M14 7a4 4 0 010 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="nav-link-text">Speaker Test</span>
        </a>
        <a href="/latency-test" class:list={['nav-link', { 'nav-active': currentPath === '/latency-test' }]}>
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 6v4.5l2.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="nav-link-text">Latency Test</span>
        </a>
      </nav>
    </div>
  </header>

  <!-- ───── CONTENT ───── -->
  {sidebar ? (
    <div class="page-layout">
      <main id="main-content" class="page-main">
        <slot />
      </main>
      <aside class="tool-sidebar" aria-label="Other tests">
        <div class="sidebar-inner">

          <a href="/mic-test" class:list={['sidebar-item', { active: currentPath === '/mic-test' }]}>
            <div class="sidebar-icon">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect x="7" y="2" width="6" height="11" rx="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M4 10a6 6 0 0012 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="10" y1="16" x2="10" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="7" y1="19" x2="13" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="sidebar-text">
              <span class="sidebar-item-title">Test your Microphone</span>
              <span class="sidebar-item-desc">Input levels &amp; recording</span>
            </div>
          </a>

          <a href="/speaker-test" class:list={['sidebar-item', { active: currentPath === '/speaker-test' }]}>
            <div class="sidebar-icon">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M3 7h3.5L11 3v14l-4.5-4H3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M14 7a4 4 0 010 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="sidebar-text">
              <span class="sidebar-item-title">Test your Speakers</span>
              <span class="sidebar-item-desc">Left, right &amp; stereo output</span>
            </div>
          </a>

          <a href="/latency-test" class:list={['sidebar-item', { active: currentPath === '/latency-test' }]}>
            <div class="sidebar-icon">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/>
                <path d="M10 6v4.5l2.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="sidebar-text">
              <span class="sidebar-item-title">Audio Latency Test</span>
              <span class="sidebar-item-desc">Bluetooth delay &amp; lag check</span>
            </div>
          </a>

        </div>
      </aside>
    </div>
  ) : (
    <main id="main-content">
      <slot />
    </main>
  )}

  <!-- ───── FOOTER ───── -->
  <footer class="footer" role="contentinfo">
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="/" class="nav-logo footer-logo">
          <img src="/icon.png" width="18" height="18" alt="" aria-hidden="true" />
          <span>onlineaudiotest</span>
        </a>
        <p class="footer-tagline">Free browser-based audio diagnostics. No download required.</p>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <span class="footer-col-label">Tools</span>
          <a href="/mic-test" class="footer-link">Mic Check Online</a>
          <a href="/speaker-test" class="footer-link">Left Right Audio Test</a>
          <a href="/speaker-test" class="footer-link">Headphone Test</a>
          <a href="/latency-test" class="footer-link">Audio Latency Test</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-label">Company</span>
          <a href="/" class="footer-link">Home</a>
          <a href="/about" class="footer-link">About Us</a>
          <a href="/contact" class="footer-link">Contact Us</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-label">Legal</span>
          <a href="/privacy" class="footer-link">Privacy Policy</a>
          <a href="/terms" class="footer-link">Terms &amp; Conditions</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom container">
      <span class="caption-mono">© {new Date().getFullYear()} OnlineAudioTest.com - All rights reserved.</span>
    </div>
  </footer>

</body>
</html>

<style is:global>
  /* ═══════════════════════════════════════════
     DESIGN SYSTEM - mirrors DESIGN.md tokens
  ═══════════════════════════════════════════ */
  :root {
    /* Fonts */
    --font-sans: 'Geist', 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'Geist Mono', ui-monospace, 'JetBrains Mono', SFMono-Regular, Menlo, monospace;

    /* Colors */
    --ink:              #171717;
    --body-text:        #4d4d4d;
    --mute:             #888888;
    --canvas:           #ffffff;
    --canvas-soft:      #fafafa;
    --canvas-soft-2:    #f5f5f5;
    --hairline:         #ebebeb;
    --hairline-strong:  #a1a1a1;
    --link:             #0070f3;
    --link-deep:        #0761d1;
    --on-primary:       #ffffff;
    --cyan:             #50e3c2;
    --success:          #0070f3;
    --error:            #ee0000;

    /* Brand gradients */
    --grad-develop: linear-gradient(to bottom, #93c5fd, #60a5fa);
    --grad-preview: linear-gradient(135deg, #7928ca 0%, #ff0080 100%);
    --grad-ship:    linear-gradient(135deg, #ff4d4d 0%, #f9cb28 100%);
    --grad-hero: radial-gradient(ellipse at 20% 50%, rgba(0,124,240,.18) 0%, transparent 60%),
                 radial-gradient(ellipse at 80% 20%, rgba(0,223,216,.14) 0%, transparent 55%),
                 radial-gradient(ellipse at 60% 80%, rgba(121,40,202,.12) 0%, transparent 55%),
                 radial-gradient(ellipse at 90% 70%, rgba(255,0,128,.10) 0%, transparent 50%),
                 radial-gradient(ellipse at 40% 10%, rgba(255,77,77,.08) 0%, transparent 50%),
                 radial-gradient(ellipse at 10% 90%, rgba(249,203,40,.08) 0%, transparent 50%);

    /* Border radius */
    --r-xs:   4px;
    --r-sm:   6px;
    --r-md:   8px;
    --r-lg:   12px;
    --r-xl:   16px;
    --r-pill: 100px;
    --r-full: 9999px;

    /* Spacing */
    --s-xxs: 4px;
    --s-xs:  8px;
    --s-sm:  12px;
    --s-md:  16px;
    --s-lg:  24px;
    --s-xl:  32px;
    --s-2xl: 40px;
    --s-3xl: 48px;
    --s-4xl: 64px;
    --s-5xl: 96px;
    --s-section: 192px;

    /* Stacked shadows (Vercel-style) */
    --shadow-1: inset 0 0 0 1px rgba(0,0,0,.08);
    --shadow-2: 0 1px 1px rgba(0,0,0,.02),0 2px 2px rgba(0,0,0,.04), inset 0 0 0 1px rgba(0,0,0,.08);
    --shadow-3: 0 2px 2px rgba(0,0,0,.04),0 8px 8px -8px rgba(0,0,0,.04), inset 0 0 0 1px rgba(0,0,0,.08);
    --shadow-4: 0 2px 2px rgba(0,0,0,.04),0 8px 16px -4px rgba(0,0,0,.04), inset 0 0 0 1px rgba(0,0,0,.08);

    /* Nav */
    --nav-height: 64px;
    --container-max: 1200px;
    --container-pad: var(--s-lg);
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }

  body {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink);
    background: var(--canvas-soft);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  ::selection { background: var(--ink); color: var(--on-primary); }

  img, video { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  button { cursor: pointer; font-family: inherit; }
  ul { list-style: none; }

  /* ── Layout helpers ── */
  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
  }

  /* ── Typography tokens ── */
  .display-xl { font-size: 48px; font-weight: 600; line-height: 48px; letter-spacing: -2.4px; }
  .display-lg { font-size: 32px; font-weight: 600; line-height: 40px; letter-spacing: -1.28px; }
  .display-md { font-size: 24px; font-weight: 600; line-height: 32px; letter-spacing: -0.96px; }
  .display-sm { font-size: 20px; font-weight: 600; line-height: 28px; letter-spacing: -0.6px; }
  .body-lg    { font-size: 18px; font-weight: 400; line-height: 28px; }
  .body-md    { font-size: 16px; font-weight: 400; line-height: 24px; }
  .body-sm    { font-size: 14px; font-weight: 400; line-height: 20px; letter-spacing: -0.28px; }
  .caption    { font-size: 12px; font-weight: 400; line-height: 16px; }
  .caption-mono { font-family: var(--font-mono); font-size: 12px; font-weight: 400; line-height: 16px; }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-xs);
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    font-weight: 500;
    transition: opacity .15s, transform .1s;
    text-decoration: none;
    white-space: nowrap;
  }
  .btn:active { transform: scale(.98); }
  .btn:disabled { opacity: .45; cursor: not-allowed; pointer-events: none; }

  .btn-primary {
    background: var(--grad-develop);
    color: var(--ink);
    font-size: 16px;
    line-height: 24px;
    border-radius: var(--r-pill);
    padding: 0 var(--s-sm);
    height: 40px;
    font-weight: 600;
  }
  .btn-primary:hover { opacity: .88; }

  .btn-secondary {
    background: var(--canvas);
    color: var(--ink);
    font-size: 16px;
    line-height: 24px;
    border-radius: var(--r-pill);
    padding: 0 var(--s-sm);
    height: 44px;
    box-shadow: var(--shadow-1);
  }
  .btn-secondary:hover { background: var(--canvas-soft-2); }

  .btn-sm {
    font-size: 14px;
    line-height: 20px;
    border-radius: var(--r-pill);
    padding: 0 var(--s-xs);
    height: 32px;
  }

  .btn-ghost {
    background: transparent;
    color: var(--body-text);
    font-size: 14px;
    border-radius: var(--r-full);
    padding: var(--s-xxs) var(--s-sm);
    height: 32px;
  }
  .btn-ghost:hover { background: var(--canvas-soft-2); }

  .btn-lg {
    font-size: 16px;
    height: 48px;
    padding: 0 var(--s-xl);
    border-radius: var(--r-pill);
  }

  /* ── Cards ── */
  .card {
    background: var(--canvas);
    border-radius: var(--r-md);
    padding: var(--s-lg);
    box-shadow: var(--shadow-2);
  }
  .card-lg {
    background: var(--canvas);
    border-radius: var(--r-lg);
    padding: var(--s-xl);
    box-shadow: var(--shadow-3);
  }
  .card-soft {
    background: var(--canvas-soft);
    border-radius: var(--r-md);
    padding: var(--s-lg);
    box-shadow: var(--shadow-1);
  }

  /* ── Badge ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--s-xxs);
    background: var(--canvas-soft);
    color: var(--body-text);
    font-family: var(--font-mono);
    font-size: 12px;
    border-radius: var(--r-full);
    padding: 0 var(--s-xs);
    height: 24px;
    box-shadow: var(--shadow-1);
  }
  .badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--hairline-strong);
    flex-shrink: 0;
  }
  .badge-dot.green  { background: #00b894; }
  .badge-dot.blue   { background: var(--link); }
  .badge-dot.purple { background: #7928ca; }

  /* ── Eyebrow label ── */
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--mute);
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  /* ════════════════════════
       NAV
  ════════════════════════ */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--hairline);
    height: var(--nav-height);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    gap: var(--s-lg);
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--s-xs);
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.3px;
    flex-shrink: 0;
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--s-xxs);
  }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--body-text);
    padding: var(--s-xs) var(--s-sm);
    border-radius: var(--r-full);
    transition: color .15s, background .15s;
    white-space: nowrap;
    text-decoration: none;
  }
  .nav-link:hover  { color: var(--ink); background: var(--canvas-soft-2); }
  .nav-link.nav-active { color: var(--ink); font-weight: 500; background: var(--canvas-soft-2); }
  .nav-link svg { flex-shrink: 0; }

  /* Mobile: icons only - no hamburger, no drawer */
  @media (max-width: 768px) {
    .nav-link-text { display: none; }
    .nav-link { padding: var(--s-xs); }
  }

  /* ════════════════════════
       FOOTER
  ════════════════════════ */
  .footer {
    background: var(--canvas);
    border-top: 1px solid var(--hairline);
    padding-top: var(--s-4xl);
    padding-bottom: var(--s-xl);
    margin-top: 0;
  }
  .footer-inner {
    display: flex;
    gap: var(--s-4xl);
    padding-bottom: var(--s-xl);
    border-bottom: 1px solid var(--hairline);
    flex-wrap: wrap;
  }
  .footer-brand {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: var(--s-sm);
  }
  .footer-logo { color: var(--body-text); }
  .footer-tagline { font-size: 14px; color: var(--mute); max-width: 260px; line-height: 1.5; }
  .footer-cols { display: flex; gap: var(--s-4xl); flex-wrap: wrap; }
  .footer-col { display: flex; flex-direction: column; gap: var(--s-xs); min-width: 120px; }
  .footer-col-label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: .06em;
    margin-bottom: var(--s-xxs);
  }
  .footer-link { font-size: 14px; color: var(--body-text); transition: color .15s; }
  .footer-link:hover { color: var(--ink); }
  .footer-bottom { padding-top: var(--s-lg); }
  .footer-bottom .caption-mono { color: var(--mute); }

  /* ════════════════════════
       TOOL PAGE COMMONS
  ════════════════════════ */
  .tool-hero {
    padding-top: var(--s-4xl);
    padding-bottom: var(--s-xl);
    text-align: center;
  }
  .tool-hero h1 {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 600;
    letter-spacing: -2px;
    line-height: 1;
    color: var(--ink);
    margin-bottom: var(--s-md);
  }
  .tool-hero p {
    font-size: 18px;
    color: var(--body-text);
    max-width: 540px;
    margin-inline: auto;
    line-height: 1.6;
  }

  .tool-card-wrap {
    max-width: 640px;
    margin-inline: auto;
    padding: 0 var(--container-pad);
    margin-bottom: var(--s-3xl);
  }

  .tool-card {
    background: var(--canvas);
    border-radius: var(--r-lg);
    padding: var(--s-xl);
    box-shadow: var(--shadow-4);
    display: flex;
    flex-direction: column;
    gap: var(--s-lg);
  }

  /* Status pill */
  .status-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-sm);
  }
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--mute);
    background: var(--canvas-soft);
    border-radius: var(--r-full);
    padding: 4px 10px;
    box-shadow: var(--shadow-1);
  }
  .status-pill .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--hairline-strong);
    transition: background .3s;
    flex-shrink: 0;
  }
  .status-pill .dot.active  { background: #60a5fa; box-shadow: 0 0 0 3px rgba(96,165,250,.25); }
  .status-pill .dot.error   { background: var(--error); }
  .status-pill .dot.warning { background: var(--warning, #f5a623); }

  /* Channel indicators */
  .channels {
    display: flex;
    gap: var(--s-sm);
    justify-content: center;
  }
  .channel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-xs);
  }
  .channel-ring {
