---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Audio Latency Test — Bluetooth & AirPods Delay Checker",
      "url": "https://onlineaudiotest.com/latency-test/",
      "description": "Free audio latency test online. Measure Bluetooth audio delay, AirPods latency, and system output lag in milliseconds. Bluetooth audio test and AirPods test — instant, no download.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "browserRequirements": "Requires Web Audio API support",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "featureList": ["Audio latency test", "Bluetooth audio test", "AirPods latency test", "System output lag measurement", "Round-trip loopback test", "Output & base latency breakdown"],
      "provider": { "@type": "Organization", "name": "OnlineAudioTest.com", "url": "https://onlineaudiotest.com/" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://onlineaudiotest.com/" },
        { "@type": "ListItem", "position": 2, "name": "Audio Latency Test", "item": "https://onlineaudiotest.com/latency-test/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why does my audio sound delayed on Bluetooth?",
          "acceptedAnswer": { "@type": "Answer", "text": "Bluetooth audio codecs compress audio before transmitting it wirelessly. The default codec (SBC) introduces 150–250 ms of delay. Two codecs genuinely reduce this: aptX Low Latency achieves approximately 40 ms, and LC3 (used in Bluetooth LE Audio) targets around 20–40 ms. LDAC is a high-quality codec, not a low-latency one — its latency is similar to SBC. Some headphones advertise a 'game mode' which switches to a low-latency protocol to reduce delay." }
        },
        {
          "@type": "Question",
          "name": "What is the difference between base latency and output latency?",
          "acceptedAnswer": { "@type": "Answer", "text": "Base latency is the fixed delay your browser's audio engine adds to process audio in chunks (typically 5–20 ms). Output latency is the additional delay introduced by your audio driver and hardware — this is where Bluetooth delay shows up. Together they form your total audio output latency, which this test measures." }
        },
        {
          "@type": "Question",
          "name": "My Zoom calls have echo — is that a latency issue?",
          "acceptedAnswer": { "@type": "Answer", "text": "Echo is different from latency. Echo happens when your microphone picks up audio from your speakers and retransmits it. Latency is when you hear your own voice with a delay. If you hear yourself delayed, your total round-trip is above 50 ms. Use wired headphones or enable echo cancellation in Zoom settings to fix both issues." }
        },
        {
          "@type": "Question",
          "name": "How can I reduce audio latency for gaming?",
          "acceptedAnswer": { "@type": "Answer", "text": "Use a wired connection rather than Bluetooth. In Windows, switch from 'High Definition Audio' to an ASIO driver (via apps like ASIO4ALL) for sub-10 ms latency. On Mac, use Core Audio which already has low-latency drivers built in. For Bluetooth gaming headsets, enable Game Mode or aptX Low Latency if available, and avoid USB audio hubs — connect directly to your motherboard's audio jack." }
        },
        {
          "@type": "Question",
          "name": "What is a good audio latency for video calls?",
          "acceptedAnswer": { "@type": "Answer", "text": "Under 40 ms is generally imperceptible during a call. 40–100 ms may cause minor lip-sync issues in video. Above 100 ms becomes noticeably disruptive during back-and-forth conversation — you'll hear yourself or others with a clear, distracting lag. Wired audio typically achieves under 20 ms; Bluetooth SBC can exceed 200 ms." }
        },
        {
          "@type": "Question",
          "name": "What is considered good audio latency?",
          "acceptedAnswer": { "@type": "Answer", "text": "Lower latency is generally preferable. Wired connections and professional audio setups often achieve very low latency, while Bluetooth audio typically introduces more delay. Whether latency is noticeable depends on the activity, the listener, and the synchronization requirements. For gaming and audio production, minimizing latency matters more than for music listening or streaming video." }
        },
        {
          "@type": "Question",
          "name": "How do I reduce audio latency on Windows?",
          "acceptedAnswer": { "@type": "Answer", "text": "The biggest improvement on Windows is switching from the default consumer audio driver to an ASIO driver. ASIO4ALL is a free option that works with most built-in audio hardware; professional USB audio interfaces also ship with ASIO drivers. ASIO drivers can significantly reduce latency compared with standard consumer audio configurations, particularly in recording and production workflows. Also use a wired connection and keep your audio driver updated." }
        },
        {
          "@type": "Question",
          "name": "How do I reduce audio latency on Mac?",
          "acceptedAnswer": { "@type": "Answer", "text": "Apple's Core Audio architecture is designed for low-latency audio performance, especially when paired with wired audio devices. To reduce latency further: use a dedicated USB audio interface, lower the buffer size in your DAW or audio app if applicable, and use wired headphones rather than Bluetooth. The buffer size setting in professional audio software is usually the most effective adjustment." }
        },
        {
          "@type": "Question",
          "name": "Why is my audio out of sync with video?",
          "acceptedAnswer": { "@type": "Answer", "text": "Audio-video sync issues have several common causes. Bluetooth delay is the most frequent: if your headphones introduce significant audio latency and the video player doesn't compensate, you'll see lips moving before you hear the words. Most streaming apps (Netflix, YouTube) compensate automatically by buffering audio and video together — sync issues are more common in live streams, browser video calls, or local video files. Most media players (VLC, IINA, etc.) have an audio delay adjustment setting to manually offset the audio track." }
        }
      ]
    }
  ]
};
---

<Layout
  title="Audio Latency Test — Measure Bluetooth & Audio Delay in ms"
  description="Measure your audio output delay in milliseconds — free, instant, in your browser. Test Bluetooth headphone lag, AirPods delay, gaming latency, or wired audio. No download or microphone required."
  keywords="audio latency test, sound latency test, latency test audio, bluetooth audio test, audio delay test, airpods latency test, bluetooth latency checker, audio lag test, airpods latency, wireless audio latency"
  schema={schema}
  sidebar={true}
>

  <!-- HERO -->
  <section class="tool-hero container">
    <h1>Audio Latency Test</h1>
    <p>Measure Bluetooth audio delay, AirPods latency, and system output lag in milliseconds. The fastest Bluetooth audio test and AirPods test — right in your browser.</p>
  </section>

  <!-- TOOL -->
  <div class="tool-card-wrap">
    <div class="tool-card" id="latency-tool">

      <!-- Status -->
      <div class="status-bar">
        <div class="status-pill">
          <span class="dot" id="status-dot"></span>
          <span id="status-text">Ready to measure</span>
        </div>
        <span class="eyebrow caption-mono" id="phase-label"></span>
      </div>

      <!-- Result panel -->
      <div class="result-panel" id="result-panel" hidden>
        <div class="latency-display">
          <span class="latency-num" id="latency-num">-</span>
          <span class="latency-unit">ms</span>
        </div>
        <div class="grade-badge" id="grade-badge"></div>
        <div class="latency-breakdown" id="latency-breakdown" hidden>
          <span class="breakdown-item">Base <strong id="base-ms">-</strong> ms</span>
          <span class="breakdown-sep">·</span>
          <span class="breakdown-item">Output <strong id="output-ms">-</strong> ms</span>
        </div>
        <p class="latency-advice" id="latency-advice"></p>
      </div>

      <!-- Actions -->
      <div class="action-row">
        <button class="btn btn-primary btn-lg" id="btn-measure" style="min-width:200px">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.4"/>
            <path d="M7 4v3.2l2 1.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Measure Latency
        </button>
        <button class="btn btn-secondary btn-sm" id="btn-roundtrip">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <rect x="4.5" y="1" width="3" height="6" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M2.5 6a3.5 3.5 0 007 0" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            <line x1="6" y1="9.5" x2="6" y2="11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          Round-Trip Test (mic)
        </button>
      </div>

      <p class="result-note" id="result-note">Measures your audio output delay. No microphone needed for the first test.</p>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <div class="how-section">
    <h2>How the latency test works</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <p class="step-body"><strong>Click "Measure Latency"</strong> to instantly read your system's audio output delay using the Web Audio API. No microphone required - this reports the delay from your software to your speakers or headphones.</p>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <p class="step-body"><strong>For a full round-trip test</strong>, click "Round-Trip Test" and allow microphone access. The tool plays a click through your speakers and detects when it arrives at your mic - measuring the total acoustic delay.</p>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <p class="step-body"><strong>Read your result.</strong> Under 20 ms is excellent (wired). 40–100 ms means Bluetooth is likely involved. Over 150 ms points to SBC codec or a slow audio driver - switch to a wired connection or enable a low-latency codec.</p>
      </div>
    </div>
  </div>

  <!-- BENCHMARK TABLE -->
  <div class="how-section">
    <h2>Audio latency by connection type</h2>
    <p class="section-intro">Connection type is the single biggest factor in audio latency. Wired audio has the lowest latency; standard Bluetooth has the highest. Relative values vary by device, driver, OS, and conditions.</p>
    <div class="level-table-wrap">
      <table class="level-table">
        <thead>
          <tr>
            <th>Connection</th>
            <th>Relative Latency</th>
            <th>Best for</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Wired (3.5mm / USB)</td>
            <td>Very low</td>
            <td>Gaming, production, live monitoring</td>
          </tr>
          <tr>
            <td>2.4 GHz wireless (USB dongle)</td>
            <td>Very low</td>
            <td>Gaming headsets</td>
          </tr>
          <tr>
            <td>Bluetooth aptX LL / LC3</td>
            <td>Lower</td>
            <td>Low-latency Bluetooth scenarios</td>
          </tr>
          <tr>
            <td>Bluetooth AAC / aptX</td>
            <td>Moderate</td>
            <td>Calls, music, streaming</td>
          </tr>
          <tr>
            <td>Bluetooth SBC</td>
            <td>Higher</td>
            <td>Universal fallback</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- WHAT CAUSES LATENCY -->
  <div class="how-section">
    <h2>What causes audio latency?</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <p class="step-body"><strong>Audio generation</strong> — Your software or app produces an audio signal. This is near-instantaneous but requires the processor to complete the current task first, adding a small variable delay that increases under CPU load.</p>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <p class="step-body"><strong>Buffering</strong> — Audio systems collect samples into chunks (buffers) before sending them to the output. Larger buffers reduce the risk of glitches but increase latency. Buffer size is adjustable in professional audio software and is often the most impactful setting to tune.</p>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <p class="step-body"><strong>Processing</strong> — Codecs, software effects, mixing, and DSP add processing time. On Bluetooth, codec compression on your device and decompression inside the headphones are the primary processing overhead. More complex codecs take more time.</p>
      </div>
      <div class="step">
        <span class="step-num">4</span>
        <p class="step-body"><strong>Transmission</strong> — For wireless audio, the encoded signal must travel over Bluetooth or 2.4 GHz radio. This step adds delay determined largely by the codec's buffering requirements — the main reason Bluetooth latency differs so much between codecs.</p>
      </div>
      <div class="step">
        <span class="step-num">5</span>
        <p class="step-body"><strong>Playback hardware</strong> — The audio driver and output hardware (DAC, amplifier, speaker, or headphone driver) introduce their own delay. This is the "output latency" reported by the Web Audio API and is where Bluetooth hardware delay is captured.</p>
      </div>
    </div>
  </div>

  <!-- WIRED VS BLUETOOTH -->
  <div class="how-section">
    <h2>Wired vs Bluetooth audio latency</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <p class="step-body"><strong>Wired audio</strong> — Signal travels through a physical cable directly to your headphones or speakers. There is no encoding, wireless transmission, or decoding — the audio path is nearly instantaneous. Best for: competitive gaming, music production, live vocal monitoring, and video editing where timing precision matters.</p>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <p class="step-body"><strong>Bluetooth audio</strong> — Audio is encoded by a codec (SBC, AAC, aptX, LDAC, LC3), transmitted wirelessly, and decoded by the headphones. Each step adds delay; the codec and its buffer are the primary source of Bluetooth latency. Lower-latency codecs (aptX LL, LC3) significantly close the gap with wired, but Bluetooth always involves more steps than a direct cable connection. <a href="/bluetooth-codec-guide/">Bluetooth codec guide: SBC, AAC, aptX, LDAC, LC3 explained →</a></p>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <p class="step-body"><strong>2.4 GHz wireless</strong> — Many gaming headsets use a proprietary 2.4 GHz USB dongle instead of standard Bluetooth. This is a different radio technology with lower overhead, typically achieving latency much closer to wired. If your headset came with a USB dongle, it likely uses 2.4 GHz rather than standard Bluetooth.</p>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="faq-section">
    <h2>Frequently asked questions</h2>
    <div class="faq-item">
      <p class="faq-q">Why does my audio sound delayed on Bluetooth?</p>
      <p class="faq-a">Bluetooth audio codecs compress audio before transmitting it wirelessly. The default codec (SBC) introduces 150–250 ms of delay. Two codecs genuinely reduce this: <a href="https://www.aptx.com/aptx-low-latency" target="_blank" rel="noopener noreferrer">aptX Low Latency (Qualcomm)</a> achieves approximately 40 ms, and LC3 (used in Bluetooth LE Audio) targets around 20–40 ms. LDAC is a high-quality codec, not a low-latency one — its latency is similar to SBC. Some headphones advertise a "game mode" which switches to a low-latency protocol to reduce delay.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">What is base latency vs output latency?</p>
      <p class="faq-a">Base latency is the fixed delay your browser's audio engine adds to process audio in chunks (typically 5–20 ms). Output latency is additional delay introduced by your audio driver and hardware - this is where Bluetooth delay shows up. Together they form your total audio delay.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">My Zoom calls have echo - is that a latency issue?</p>
      <p class="faq-a">Echo is different from latency. Echo happens when your microphone picks up audio from your speakers. Latency is when you hear your own voice with a delay. If you hear yourself delayed, your total round-trip is above 50 ms - use wired headphones or enable echo cancellation in Zoom settings.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">How can I reduce audio latency for gaming?</p>
      <p class="faq-a">Use a wired connection rather than Bluetooth. In Windows, switch from "High Definition Audio" to an ASIO driver (via apps like ASIO4ALL) for sub-10 ms latency. On Mac, use Core Audio which already has low-latency drivers built in. Avoid USB audio hubs - connect directly to your motherboard's audio jack.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">What is a good latency for video calls?</p>
      <p class="faq-a">Under 40 ms is generally imperceptible during a call. 40–100 ms may cause minor lip-sync issues in video. Above 100 ms becomes noticeably annoying during back-and-forth conversation — you'll hear yourself or others with a clear lag.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">What is considered good audio latency?</p>
      <p class="faq-a">Lower latency is generally preferable. Wired connections and professional audio setups often achieve very low latency, while Bluetooth audio typically introduces more delay. Whether latency is noticeable depends on the activity, the listener, and the synchronization requirements — gaming and audio production demand lower latency than music listening or video streaming.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">How do I reduce audio latency on Windows?</p>
      <p class="faq-a">The biggest improvement on Windows is switching from the default consumer audio driver to an ASIO driver. ASIO4ALL is a free option that works with most built-in audio hardware; professional USB audio interfaces ship with their own ASIO drivers. ASIO drivers can significantly reduce latency compared with standard consumer audio configurations, particularly in recording and production workflows. Also use a wired connection and keep your audio driver updated.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">How do I reduce audio latency on Mac?</p>
      <p class="faq-a">Apple's Core Audio architecture is designed for low-latency audio performance, especially when paired with wired audio devices. To reduce latency further: use a dedicated USB audio interface, lower the buffer size in your DAW or audio app if applicable, and use wired headphones rather than Bluetooth. Buffer size is usually the most effective setting to tune in professional audio software on Mac.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">Why is my audio out of sync with video?</p>
      <p class="faq-a">Bluetooth delay is the most common cause — if your headphones introduce significant latency and the video player doesn't compensate, you'll see lips moving before you hear the words. Most streaming apps (Netflix, YouTube) compensate automatically by buffering both streams together, so sync issues are more common in live streams, browser video calls, or local video files. If you're watching a local file, most media players (VLC, IINA, etc.) have an audio delay adjustment setting that lets you manually offset the audio track to match the video.</p>
    </div>
  </div>

  <!-- RELATED TESTS -->
  <div class="how-section">
    <h2>Device-specific latency tests</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">→</span>
        <p class="step-body"><a href="/airpods-latency-test/"><strong>AirPods Latency Test</strong></a> — Specific guidance for AirPods, AirPods Pro, and AirPods Max. Covers why latency spikes when AirPods are used as a Mac microphone and how to fix it.</p>
      </div>
      <div class="step">
        <span class="step-num">→</span>
        <p class="step-body"><a href="/bluetooth-latency-test/"><strong>Bluetooth Latency Test</strong></a> — Focused on Bluetooth codecs: SBC, AAC, aptX, LDAC, and LC3. Includes a codec comparison table and how to switch codecs on Android.</p>
      </div>
    </div>
  </div>

</Layout>

<script>
  (() => {
    type Phase = 'idle' | 'measuring' | 'result' | 'rt-requesting' | 'rt-running' | 'rt-result';

    let phase: Phase = 'idle';
    let audioCtx: AudioContext | null = null;

    const btnMeasure   = document.getElementById('btn-measure') as HTMLButtonElement;
    const btnRoundtrip = document.getElementById('btn-roundtrip') as HTMLButtonElement;
    const statusDot    = document.getElementById('status-dot')!;
    const statusText   = document.getElementById('status-text')!;
    const phaseLabel   = document.getElementById('phase-label')!;
    const resultPanel  = document.getElementById('result-panel')!;
    const latencyNum   = document.getElementById('latency-num')!;
    const gradeBadge   = document.getElementById('grade-badge')!;
    const breakdown    = document.getElementById('latency-breakdown')!;
    const baseMs       = document.getElementById('base-ms')!;
    const outputMs     = document.getElementById('output-ms')!;
    const latencyAdvice = document.getElementById('latency-advice')!;
    const resultNote   = document.getElementById('result-note')!;

    function getCtx() {
      if (!audioCtx) audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      return audioCtx;
    }

    function setStatus(active: boolean, warning: boolean, text: string) {
      statusText.textContent = text;
      statusDot.className = 'dot' + (active ? ' active' : warning ? ' warning' : '');
    }

    function grade(ms: number): { label: string; cls: string; advice: string } {
      if (ms < 10) return {
        label: 'Excellent',
        cls: 'grade-excellent',
        advice: 'Near-zero latency. Ideal for music production, gaming, and real-time monitoring. Your audio setup is optimized.'
      };
      if (ms < 40) return {
        label: 'Good',
        cls: 'grade-good',
        advice: 'Typical range for wired headphones and speakers. Generally imperceptible in everyday use.'
      };
      if (ms < 100) return {
        label: 'Noticeable',
        cls: 'grade-fair',
        advice: 'Likely Bluetooth audio (aptX or AAC codec). May cause lip-sync drift in video calls. Consider enabling a low-latency codec in your device settings.'
      };
      return {
        label: 'High - Bluetooth delay',
        cls: 'grade-poor',
        advice: 'High latency detected - likely Bluetooth SBC codec or slow audio driver. Switch to wired audio or enable aptX Low Latency / LDAC for calls and gaming.'
      };
    }

    function showResult(ms: number, label: string, baseVal?: number, outputVal?: number) {
      const g = grade(ms);
      latencyNum.textContent = ms < 1 ? '<1' : ms.toFixed(ms < 10 ? 1 : 0);
      gradeBadge.textContent = g.label;
      gradeBadge.className = 'grade-badge ' + g.cls;
      latencyAdvice.textContent = g.advice;
      phaseLabel.textContent = label;

      if (baseVal !== undefined && outputVal !== undefined) {
        baseMs.textContent = baseVal.toFixed(1);
        outputMs.textContent = outputVal.toFixed(1);
        breakdown.hidden = false;
      } else {
        breakdown.hidden = true;
      }

      resultPanel.hidden = false;
    }

    async function measureSystem() {
      phase = 'measuring';
      setStatus(true, false, 'Measuring…');
      btnMeasure.disabled = true;
      btnRoundtrip.disabled = true;
      resultNote.textContent = 'Initializing audio context…';

      const ctx = getCtx();
      if (ctx.state === 'suspended') await ctx.resume();

      // Play a silent buffer to warm up the context and get accurate latency values
      const warmup = ctx.createBuffer(1, ctx.sampleRate * 0.1, ctx.sampleRate);
      const src = ctx.createBufferSource();
      src.buffer = warmup;
      src.connect(ctx.destination);
      src.start();

      await new Promise<void>(r => setTimeout(r, 150));

      const base   = (ctx.baseLatency   ?? 0) * 1000;
      const output = (ctx.outputLatency ?? 0) * 1000;
      const total  = base + output;

      phase = 'result';
      setStatus(false, false, 'Measurement complete');

      if (total < 0.5) {
        // Browser doesn't expose latency values (e.g. Safari)
        showResult(0, 'System latency');
        resultNote.textContent = 'Your browser does not expose latency values. Use the Round-Trip Test for a measurement.';
        resultNote.className = 'result-note';
      } else {
        showResult(total, 'System latency', base, output);
        resultNote.textContent = 'System latency measured. Run the round-trip test for full acoustic delay.';
        resultNote.className = 'result-note success';
      }

      btnMeasure.textContent = 'Measure Again';
      btnMeasure.disabled = false;
      btnRoundtrip.disabled = false;
    }

    async function runRoundTrip() {
      phase = 'rt-requesting';
      setStatus(false, true, 'Requesting mic…');
      btnMeasure.disabled = true;
      btnRoundtrip.disabled = true;
      resultNote.textContent = 'Allow microphone access to run the round-trip test.';
      resultNote.className = 'result-note';

      let stream: MediaStream;
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          audio: { echoCancellation: false, noiseSuppression: false, autoGainControl: false }
        });
      } catch {
        setStatus(false, false, 'Mic access denied');
        resultNote.textContent = 'Microphone access is required for the round-trip test.';
        resultNote.className = 'result-note error';
        btnMeasure.disabled = false;
        btnRoundtrip.disabled = false;
        phase = 'result';
        return;
      }

      phase = 'rt-running';
      setStatus(true, false, 'Running round-trip test…');
      resultNote.textContent = 'Keep your microphone near your speakers or headphone mic. Running test…';

      const ctx = getCtx();
      if (ctx.state === 'suspended') await ctx.resume();

      const micSrc  = ctx.createMediaStreamSource(stream);
      const analyser = ctx.createAnalyser();
      analyser.fftSize = 256;
      micSrc.connect(analyser);

      // Measure baseline RMS over 400ms
      const baseline = await measureBaseline(analyser, 400);

      // Play 10ms white noise burst - loud enough to detect over ambient noise
      const clickDelay = 0.3;
      const clickAt = ctx.currentTime + clickDelay;
      playImpulse(ctx, clickAt, 0.85);
      const clickWallMs = Date.now() + clickDelay * 1000;

      // Poll until we detect the impulse in the mic
      const latencyMs = await detectImpulse(analyser, baseline, clickWallMs);

      stream.getTracks().forEach(t => t.stop());
      micSrc.disconnect();

      phase = 'rt-result';
      setStatus(false, false, 'Test complete');

      if (latencyMs === null) {
        resultNote.textContent = 'Could not detect the test click. Make sure your speakers are audible and try again in a quieter environment.';
        resultNote.className = 'result-note error';
      } else {
        showResult(latencyMs, 'Round-trip latency');
        resultNote.textContent = 'Round-trip latency measured. This includes speaker → air → mic delay.';
        resultNote.className = 'result-note success';
      }

      btnMeasure.disabled = false;
      btnRoundtrip.disabled = false;
    }

    function measureBaseline(analyser: AnalyserNode, durationMs: number): Promise<number> {
      return new Promise(resolve => {
        const buf = new Uint8Array(analyser.frequencyBinCount);
        let sum = 0, count = 0;
        const start = Date.now();
        const tick = () => {
          analyser.getByteTimeDomainData(buf);
          let s = 0;
          for (let i = 0; i < buf.length; i++) s += ((buf[i] / 128) - 1) ** 2;
          sum += Math.sqrt(s / buf.length);
          count++;
          if (Date.now() - start < durationMs) requestAnimationFrame(tick);
          else resolve(count > 0 ? sum / count : 0);
        };
        tick();
      });
    }

    function playImpulse(ctx: AudioContext, when: number, gain: number) {
      const duration = 0.01; // 10ms
      const buf = ctx.createBuffer(1, Math.floor(ctx.sampleRate * duration), ctx.sampleRate);
      const data = buf.getChannelData(0);
      for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1);

      const gainNode = ctx.createGain();
      gainNode.gain.value = gain;
      gainNode.connect(ctx.destination);

      const src = ctx.createBufferSource();
      src.buffer = buf;
      src.connect(gainNode);
      src.start(when);
    }

    function detectImpulse(analyser: AnalyserNode, baseline: number, clickWallMs: number): Promise<number | null> {
      return new Promise(resolve => {
        const threshold = Math.max(baseline * 3.5, 0.05);
        const buf = new Uint8Array(analyser.frequencyBinCount);
        const giveUpAt = clickWallMs + 3000;

        const poll = () => {
          const now = Date.now();
          if (now > giveUpAt) { resolve(null); return; }

          analyser.getByteTimeDomainData(buf);
          let s = 0;
          for (let i = 0; i < buf.length; i++) s += ((buf[i] / 128) - 1) ** 2;
          const rms = Math.sqrt(s / buf.length);

          if (now >= clickWallMs && rms > threshold) {
            resolve(now - clickWallMs);
            return;
          }

          setTimeout(poll, 4);
        };

        // Start polling 50ms before the click is due
        const waitMs = Math.max(0, clickWallMs - Date.now() - 50);
        setTimeout(poll, waitMs);
      });
    }

    btnMeasure.addEventListener('click', measureSystem);
    btnRoundtrip.addEventListener('click', runRoundTrip);
  })();
</script>

