---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Headphone Test Online",
      "url": "https://onlineaudiotest.com/headphone-test/",
      "description": "Free online headphone test. Check left and right channels, driver balance, bass, treble, and distortion for headphones, earbuds, gaming headsets, and AirPods.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "browserRequirements": "Requires Web Audio API (Chrome, Firefox, Safari, Edge)",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "featureList": ["Left right headphone channel test", "Frequency sweep 20Hz to 20kHz", "Driver matching test at 1kHz", "Bass test at 100Hz", "Distortion detection", "Works with AirPods and gaming headsets", "No download required"],
      "provider": { "@type": "Organization", "name": "OnlineAudioTest.com", "url": "https://onlineaudiotest.com/" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://onlineaudiotest.com/" },
        { "@type": "ListItem", "position": 2, "name": "Headphone Test", "item": "https://onlineaudiotest.com/headphone-test/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How do I test my headphones online?", "acceptedAnswer": { "@type": "Answer", "text": "Click 'Left ear' to confirm sound in your left ear only, then 'Right ear' for your right ear. Run the frequency sweep to check full-range driver response. The entire test takes under three minutes." } },
        { "@type": "Question", "name": "Why is one earbud quieter than the other?", "acceptedAnswer": { "@type": "Answer", "text": "Clean the mesh with a dry brush first — earwax blockage is the most common cause. If cleaning does not help, check the OS balance setting. If balance is centred and one driver is still quieter, the driver has degraded." } },
        { "@type": "Question", "name": "How do I fix reversed headphone channels?", "acceptedAnswer": { "@type": "Answer", "text": "Wired: replace the cable. Bluetooth: update firmware, then factory reset. USB headset: check companion app for a channel remap setting. Windows: disable Spatial Sound by right-clicking the speaker icon." } },
        { "@type": "Question", "name": "Can I test AirPods with this tool?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Open this page in Safari with AirPods connected. Run the left/right test. If channels are reversed, re-insert the buds and check Settings → Accessibility → Audio/Visual → Balance." } },
        { "@type": "Question", "name": "What is driver mismatch in headphones?", "acceptedAnswer": { "@type": "Answer", "text": "Driver mismatch means one driver produces more volume than the other at the same input. Even a 1 dB difference is audible in headphones as the stereo image pulling to one side." } },
        { "@type": "Question", "name": "How do I test a gaming headset?", "acceptedAnswer": { "@type": "Answer", "text": "Disable virtual surround first: in Windows, right-click the speaker icon and set Spatial sound to Off, then disable surround in the companion app. Run the channel test — if channels are correct with surround off, the hardware is fine." } },
        { "@type": "Question", "name": "Why does one earbud only work when I push the jack in further?", "acceptedAnswer": { "@type": "Answer", "text": "The 3.5mm socket's spring contacts are worn. If pushing the jack in fully fixes it temporarily, the cable or socket needs replacement." } },
        { "@type": "Question", "name": "Does this headphone test work with Bluetooth headphones?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Bluetooth latency causes the tone to play slightly late, but channel and frequency accuracy are unaffected. For latency testing, use the Bluetooth Latency Test." } },
        { "@type": "Question", "name": "What does the frequency sweep test?", "acceptedAnswer": { "@type": "Answer", "text": "It plays tones from 20Hz to 20kHz over 20 seconds. Any frequency range that sounds absent, distorted, or unequal between ears identifies a driver problem." } },
        { "@type": "Question", "name": "How do I fix audio only playing in one ear on Windows?", "acceptedAnswer": { "@type": "Answer", "text": "Three checks: (1) Settings → Accessibility → Audio → Mono Audio is OFF. (2) Settings → System → Sound → device Properties → Balance is centred. (3) The correct output device is selected." } },
        { "@type": "Question", "name": "Why do my headphones sound fine with music but show a problem in the test?", "acceptedAnswer": { "@type": "Answer", "text": "Music masks small imbalances. Test tones expose them because there is nothing to mask them. A problem the test reveals is real — it is just harder to notice during normal listening." } },
        { "@type": "Question", "name": "Do open-back headphones test differently than closed-back?", "acceptedAnswer": { "@type": "Answer", "text": "The channel test is identical. The frequency sweep will show bass rolloff below 80–100Hz in open-back models — that is by design, not damage." } },
        { "@type": "Question", "name": "How can I tell if my headphones are dying?", "acceptedAnswer": { "@type": "Answer", "text": "Signs include distortion at moderate volume on one driver, treble rolling off on one side, or bass disappearing despite correct fit. If the problem is on one driver only and started recently, that driver is failing." } },
        { "@type": "Question", "name": "My Bluetooth headphones sound worse than wired. Is that normal?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, if SBC codec is active. SBC compresses aggressively. If your headphones support AAC, aptX, or LDAC and your source supports the same codec, switching to it improves quality significantly." } },
        { "@type": "Question", "name": "What is the one-ear swap test?", "acceptedAnswer": { "@type": "Answer", "text": "Put the right cup on your left ear. If the problem moves with the cup, the driver is the issue. If the same ear has the problem regardless of which cup is on it, it is your ear canal, not the headphone." } }
      ]
    }
  ]
};
---

<Layout
  title="Headphone Test Online — Free Left Right & Balance Check"
  description="Test your headphones, earbuds, or AirPods online. Check left/right channels, driver balance, bass, treble, and distortion free in your browser."
  keywords="headphone test online, headphone test, left right headphone test, earbud test, AirPods test, headphone balance test, headphone driver test, gaming headset test, bluetooth headphone test, frequency sweep headphone test"
  schema={schema}
  sidebar={true}
>

  <!-- HERO -->
  <section class="tool-hero container">
    <h1>Headphone Test Online</h1>
    <p>Test your headphones, earbuds, gaming headset, or AirPods directly in your browser. Check left and right channels, driver balance, bass, treble, and distortion — in under three minutes, no download required.</p>
  </section>

  <!-- TOOL -->
  <div class="tool-card-wrap">
    <div class="tool-card" id="hp-tool">

      <div class="status-bar">
        <div class="status-pill">
          <span class="dot" id="hp-dot"></span>
          <span id="hp-status">Ready to test</span>
        </div>
      </div>

      <div class="hp-diagram" aria-label="Headphone channel visualization">
        <div class="ear-block" id="ear-left">
          <div class="ear-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <ellipse cx="20" cy="22" rx="12" ry="14" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="20" cy="22" r="5" stroke="currentColor" stroke-width="1" opacity="0.4"/>
              <path d="M12 14 Q10 7 16 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="ear-label">Left</span>
          <div class="ear-pulse" id="hp-pulse-left" aria-hidden="true"></div>
        </div>

        <div class="hp-center">
          <div class="vol-ring">
            <span class="vol-pct" id="hp-vol-pct">60</span>
            <span class="vol-unit">%</span>
          </div>
          <span class="sweep-hz" id="sweep-hz"></span>
        </div>

        <div class="ear-block" id="ear-right">
          <div class="ear-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <ellipse cx="20" cy="22" rx="12" ry="14" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="20" cy="22" r="5" stroke="currentColor" stroke-width="1" opacity="0.4"/>
              <path d="M28 14 Q30 7 24 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="ear-label">Right</span>
          <div class="ear-pulse" id="hp-pulse-right" aria-hidden="true"></div>
        </div>
      </div>

      <div class="vol-row">
        <span class="eyebrow">Volume</span>
        <input type="range" id="hp-vol" min="0" max="100" value="60" class="vol-slider" aria-label="Test volume" />
        <span class="vol-hint caption-mono">Set to 40–60% — high volume can cause hearing damage</span>
      </div>

      <div class="freq-row">
        <span class="eyebrow">Signal type</span>
        <div class="freq-chips">
          <button class="freq-chip active" data-freq="pink">
            Pink noise <span class="chip-badge">full spectrum</span>
          </button>
          <button class="freq-chip" data-freq="100">100 Hz <span class="chip-sub">bass</span></button>
          <button class="freq-chip" data-freq="1000">1 kHz <span class="chip-sub">driver match</span></button>
          <button class="freq-chip" data-freq="sweep">Freq sweep <span class="chip-sub">20→20k</span></button>
        </div>
      </div>

      <div class="action-row">
        <button class="btn btn-secondary btn-sm" id="hp-btn-left">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Left ear
        </button>
        <button class="btn btn-primary btn-lg" id="hp-btn-both" style="min-width:148px">
          <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true"><path d="M2.5 1.5l7 4-7 4V1.5z" fill="currentColor"/></svg>
          Run Test
        </button>
        <button class="btn btn-secondary btn-sm" id="hp-btn-right">
          Right ear
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

      <p class="result-note" id="hp-result">Select a signal and a channel to begin.</p>
    </div>
  </div>

  <!-- QUICK RESULTS GUIDE -->
  <div class="how-section">
    <h2>Quick Results Guide</h2>
    <p>Read your result immediately after each test:</p>
    <table class="data-table">
      <thead>
        <tr><th>What you hear</th><th>Result</th></tr>
      </thead>
      <tbody>
        <tr><td>Sound only in left ear during Left test</td><td>✅ Pass</td></tr>
        <tr><td>Sound only in right ear during Right test</td><td>✅ Pass</td></tr>
        <tr><td>Both ears play during a single-channel test</td><td>❌ Fail — channels mixing</td></tr>
        <tr><td>One side noticeably quieter</td><td>⚠️ Possible balance issue</td></tr>
        <tr><td>Sound comes from the wrong ear</td><td>❌ Channels reversed</td></tr>
        <tr><td>Buzzing or rattling at any volume</td><td>❌ Driver or debris issue</td></tr>
        <tr><td>Crackling only at high volume</td><td>⚠️ Volume too high — lower it</td></tr>
        <tr><td>One ear completely silent</td><td>❌ Cable, connection, or driver failure</td></tr>
      </tbody>
    </table>
  </div>

  <!-- WHAT EACH TEST CHECKS -->
  <div class="how-section">
    <h2>What Each Test Checks</h2>
    <table class="data-table">
      <thead>
        <tr><th>Test</th><th>What it checks</th></tr>
      </thead>
      <tbody>
        <tr><td>Left / Right test</td><td>Channel correctness — each ear gets only its signal</td></tr>
        <tr><td>Driver match (1 kHz)</td><td>Volume balance between left and right drivers</td></tr>
        <tr><td>Bass test (100 Hz)</td><td>Low-frequency response and driver seal</td></tr>
        <tr><td>Frequency sweep</td><td>Full-range performance across all drivers</td></tr>
        <tr><td>Pink noise</td><td>Overall tonal balance, left vs right comparison</td></tr>
        <tr><td>Any signal with distortion</td><td>Physical driver damage or debris</td></tr>
      </tbody>
    </table>
  </div>

  <!-- HOW TO TEST -->
  <div class="how-section">
    <h2>How to Test Your Headphones</h2>

    <p><strong>Before you start:</strong></p>
    <ul>
      <li>Wear your headphones correctly. Over-ear pads should fully encircle your ear. IEMs need a proper seal to produce accurate bass.</li>
      <li>Disable any virtual surround (Spatial Sound on Windows, Dolby Atmos, Razer 7.1, DTS Headphone:X). These deliberately mix channels and will cause the left/right test to appear to fail on a working headset.</li>
      <li>Set volume to 40–60%. Testing at high volume risks hearing damage and can trigger distortion that is not a hardware problem.</li>
    </ul>

    <p><strong>Test sequence:</strong></p>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <p class="step-body"><strong>Left / Right test</strong> — confirm each ear receives only its channel</p>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <p class="step-body"><strong>Driver match (1 kHz)</strong> — confirm both ears are equally loud</p>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <p class="step-body"><strong>Frequency sweep</strong> — listen for anything that drops out or changes on one side</p>
      </div>
      <div class="step">
        <span class="step-num">4</span>
        <p class="step-body"><strong>Distortion check</strong> — during any signal, listen for buzzing, crackling, or rattling at moderate volume</p>
      </div>
    </div>
  </div>

  <!-- LEFT RIGHT TEST -->
  <div class="how-section">
    <h2>Left Right Headphone Test</h2>
    <p>Click <strong>"Left ear"</strong> — sound in your left ear only, right ear silent. Click <strong>"Right ear"</strong> — sound in your right ear only, left ear silent.</p>

    <p><strong>If channels are reversed (left audio in right ear):</strong></p>
    <table class="data-table">
      <thead>
        <tr><th>Device type</th><th>Fix</th></tr>
      </thead>
      <tbody>
        <tr><td>Wired headphones</td><td>Replace the cable — internal wiring is crossed</td></tr>
        <tr><td>Bluetooth headphones</td><td>Disconnect, re-pair; check OS for channel swap setting</td></tr>
        <tr><td>AirPods</td><td>Settings → Accessibility → Audio/Visual → Balance → centre; re-insert both buds</td></tr>
        <tr><td>USB gaming headset</td><td>Check companion software (G Hub, Razer Synapse, SteelSeries GG) for channel remap</td></tr>
        <tr><td>3.5mm gaming headset</td><td>Confirm plugged into headphone port, not mic port</td></tr>
      </tbody>
    </table>

    <p><strong>If one ear produces no sound:</strong></p>
    <ul>
      <li><strong>Wired:</strong> wiggle the cable at the jack. Sound that flickers means the break is near the connector.</li>
      <li><strong>True wireless:</strong> reseat in charging case for 10 seconds, then re-pair.</li>
      <li><strong>Any device:</strong> check that Mono Audio is not enabled. Windows: Settings → Accessibility → Audio → Mono Audio → Off. Mac: System Settings → Accessibility → Audio → Mono Audio → uncheck.</li>
    </ul>
  </div>

  <!-- BALANCE TEST -->
  <div class="how-section">
    <h2>Headphone Balance Test</h2>
    <p>Because the driver sits against your ear, even a 1 dB difference between sides is immediately audible. Play the 1 kHz driver match signal. Close your eyes. The tone should appear as a single point centred in your head. If it pulls left or right, one driver is louder.</p>

    <p><strong>Software fix first:</strong></p>
    <ul>
      <li>Windows: Settings → System → Sound → device Properties → Balance → centre</li>
      <li>Mac: System Settings → Sound → Output → Balance → centre</li>
    </ul>

    <p><strong>If balance is centred in the OS but still sounds uneven:</strong><br />Clean the mesh on the quieter earbud with a dry soft brush before assuming driver damage — earwax blockage is the cause in the majority of cases. IEM users: check that both tips are the same size and seated at the same depth.</p>
  </div>

  <!-- BASS TEST -->
  <div class="how-section">
    <h2>Bass Test</h2>
    <p>Select <strong>100 Hz</strong> and play on both ears. Bass should feel full and equal on both sides.</p>

    <p><strong>IEMs:</strong> Bass depends entirely on ear tip seal. If the tip does not seal the canal, bass collapses by 15–20 dB. Push the IEM slightly deeper. If bass returns, it was a seal problem. Try a larger tip size.</p>

    <p><strong>Over-ear headphones:</strong> The ear pad must fully encircle your ear. A gap from glasses frames or compressed foam dramatically reduces bass. Check that the pad makes full contact before assuming a driver problem.</p>

    <p><strong>Bluetooth headphones:</strong> If bass sounds weak via Bluetooth but correct when wired, the codec is compressing it. SBC has the lowest quality — if your headphones support AAC, aptX, or LDAC, ensure you are connected with that codec.</p>

    <p><strong>Pass:</strong> Bass frequencies feel full and equal in both ears.<br />
    <strong>Fail:</strong> Bass absent on one side, or weak on both despite correct fit — driver or seal problem.</p>
  </div>

  <!-- TREBLE TEST -->
  <div class="how-section">
    <h2>Treble Test</h2>
    <p>During the frequency sweep, pay attention as it climbs above 4 kHz. Treble should remain clear up to at least 12–14 kHz for most adults.</p>

    <ul>
      <li><strong>Treble present but harsh or metallic</strong> — not damage; likely the headphone's natural tuning or volume too high</li>
      <li><strong>Treble cuts off on one side earlier than the other</strong> — driver degradation on that ear</li>
      <li><strong>Hissing or crackling that intensifies with frequency</strong> — physical damage to the driver</li>
    </ul>

    <p>Wearing position affects treble: high-frequency response is sensitive to driver angle and distance. If treble sounds thin or harsh, adjust the fit before assuming a hardware problem.</p>
  </div>

  <!-- DISTORTION TEST -->
  <div class="how-section">
    <h2>Distortion Test</h2>
    <p>Play any signal at moderate volume (40–60%). A healthy driver produces a clean tone with nothing extra. Listen for:</p>
    <table class="data-table">
      <thead>
        <tr><th>Sound</th><th>Likely cause</th></tr>
      </thead>
      <tbody>
        <tr><td>Buzzing at all volumes</td><td>Debris inside the driver cavity (common in IEMs — clean first)</td></tr>
        <tr><td>Rattling that changes with frequency</td><td>Loose internal component</td></tr>
        <tr><td>Crackling at low and high volume</td><td>Driver damage — replace</td></tr>
        <tr><td>Crackling only at high volume</td><td>Volume too high — lower it, not a hardware problem</td></tr>
        <tr><td>Distortion only on one side</td><td>That driver is damaged</td></tr>
      </tbody>
    </table>
  </div>

  <!-- GAMING HEADSET TEST -->
  <div class="how-section">
    <h2>Gaming Headset Test</h2>
    <p>Virtual surround software (Dolby Atmos for Headphones, Windows Sonic, DTS Headphone:X, Razer 7.1) deliberately mixes channels to simulate surround. When active, the left/right test will appear to fail even on a working headset — sound bleeds between ears by design.</p>

    <p><strong>Disable virtual surround before testing:</strong></p>
    <ul>
      <li>Windows: right-click speaker icon → Spatial sound → Off</li>
      <li>Razer Synapse: Headset → 7.1 Surround → Off</li>
      <li>Logitech G Hub: Headset → DTS → Off</li>
      <li>SteelSeries GG: Headset → Surround → Off</li>
    </ul>

    <p>Then run the channel test. If channels are correct with surround off, the hardware is fine — the HRTF mapping was causing the apparent failure.</p>

    <p><strong>USB vs 3.5mm headsets:</strong> USB gaming headsets have their own DAC. If the headset sounds wrong, check the companion app's mixer levels first. 3.5mm headsets with a TRRS cable need a splitter adapter if your PC only has separate headphone and mic ports.</p>
  </div>

  <!-- BLUETOOTH TEST -->
  <div class="how-section">
    <h2>Bluetooth Headphone Test</h2>
    <p>Bluetooth introduces latency but does not affect channel accuracy. Codec quality, however, affects what you hear.</p>

    <p><strong>Codec quality (highest to lowest):</strong> LDAC → aptX Adaptive → aptX HD → aptX → AAC → SBC. If your headphones sound compressed or narrow via Bluetooth, a lower-quality codec is active.</p>
    <ul>
      <li>Android: Settings → Developer Options → Bluetooth Audio Codec shows active codec</li>
      <li>iOS: AAC is the maximum for most headphones</li>
      <li>Windows: check the companion app</li>
    </ul>

    <p><strong>If channels are reversed via Bluetooth:</strong> Update headphone firmware through the companion app. If no update fixes it, factory reset the headphones and re-pair.</p>

    <p><strong>Connection dropout causing one-sided audio:</strong> Interference from 2.4GHz Wi-Fi, low battery (true wireless), or distance from the source are the most common causes. Move closer and test again.</p>

    <p>For measuring actual Bluetooth audio delay, use the <a href="/bluetooth-latency-test/">Bluetooth Latency Test</a>.</p>
  </div>

  <!-- AIRPODS TEST -->
  <div class="how-section">
    <h2>AirPods &amp; Wireless Earbuds Test</h2>

    <p><strong>AirPods L/R assignment:</strong> AirPods use proximity sensors to detect which ear they are in. If inserted correctly but channels are still reversed, go to Settings → Accessibility → Audio/Visual → Balance and confirm the slider is centred.</p>

    <p><strong>One AirPod quieter:</strong> Clean the mesh first — earwax blockage is the cause in the majority of cases. Use a dry soft-bristle brush. If cleaning does not help, reset: hold the case button until the amber light flashes.</p>

    <p><strong>Automatic Ear Detection misfiring:</strong> If one AirPod pauses or goes silent intermittently: Settings → Bluetooth → your AirPods → Automatic Ear Detection → toggle off and back on.</p>

    <p><strong>ANC and Transparency mode:</strong> Test in Normal mode (no ANC, no Transparency) for accurate driver results. ANC applies DSP that changes frequency response — distortion that appears only in ANC mode is the ANC processing, not the driver.</p>

    <p><strong>True wireless (Galaxy Buds, Sony WF, Jabra):</strong> One bud connects as primary, the other as secondary. If the secondary drops out, reseat both in the case for 10 seconds. Factory reset if the problem persists.</p>
  </div>

  <!-- COMMON PROBLEMS -->
  <div class="how-section">
    <h2>Common Headphone Problems</h2>

    <div class="problem-block">
      <h3>One Earbud Not Working</h3>
      <p>First confirm the problem is the earbud: plug a different pair into the same device. If the new pair works on both sides, the problem is the original earbud.</p>
      <table class="data-table">
        <thead><tr><th>Cause</th><th>Fix</th></tr></thead>
        <tbody>
          <tr><td>Cable open circuit</td><td>Wiggle at the jack — if sound flickers, replace the cable</td></tr>
          <tr><td>True wireless out of charge</td><td>Reseat in case for 10 seconds</td></tr>
          <tr><td>True wireless sync failure</td><td>Forget device, factory reset, re-pair</td></tr>
          <tr><td>AirPods ear detection</td><td>Settings → Bluetooth → AirPods → Automatic Ear Detection → toggle</td></tr>
          <tr><td>Driver failure</td><td>If all above fail, the driver is physically dead</td></tr>
        </tbody>
      </table>
    </div>

    <div class="problem-block">
      <h3>Left Earbud Quieter Than Right</h3>
      <table class="data-table">
        <thead><tr><th>Cause</th><th>Fix</th></tr></thead>
        <tbody>
          <tr><td>Earwax on mesh</td><td>Clean with dry soft brush — most common cause</td></tr>
          <tr><td>IEM tip wrong size or depth</td><td>Reseat with correct tip for proper seal</td></tr>
          <tr><td>OS balance shifted</td><td>Windows/Mac balance slider — centre it</td></tr>
          <tr><td>Driver degradation</td><td>EQ compensation (temporary) or replace headphones</td></tr>
        </tbody>
      </table>
    </div>

    <div class="problem-block">
      <h3>Audio Only Playing In One Ear</h3>
      <p>For wired headphones: the 3.5mm jack is not fully inserted. A partially inserted jack commonly produces mono from one ear only — push it in firmly until it clicks.</p>
      <p>For any device: check Mono Audio. Windows: Settings → Accessibility → Audio → Mono Audio → Off. Mac: System Settings → Accessibility → Audio → Mono Audio → uncheck. Mono Audio collapses both channels to one ear even when headphones are the selected output.</p>
    </div>

    <div class="problem-block">
      <h3>Headphone Channels Reversed</h3>
      <table class="data-table">
        <thead><tr><th>Device type</th><th>Cause</th><th>Fix</th></tr></thead>
        <tbody>
          <tr><td>Wired headphones</td><td>Cable internally crossed</td><td>Replace cable</td></tr>
          <tr><td>USB headset</td><td>Software channel remap</td><td>Check companion app, restore defaults</td></tr>
          <tr><td>Bluetooth</td><td>Firmware channel assignment</td><td>Update firmware, factory reset</td></tr>
          <tr><td>Any device + Windows</td><td>Spatial Audio remap</td><td>Right-click speaker icon → Spatial sound → Off</td></tr>
        </tbody>
      </table>
    </div>

    <div class="problem-block">
      <h3>Bluetooth Audio Delay</h3>
      <p>Bluetooth headphones introduce latency that varies by codec: SBC is highest (~150–200ms), aptX LL reaches ~40ms, AirPods on Apple devices can reach ~9ms. This tool does not measure latency — use the <a href="/latency-test/">Audio Latency Test</a> or <a href="/bluetooth-latency-test/">Bluetooth Latency Test</a>.</p>
    </div>
  </div>

  <!-- HOW TO TELL IF DAMAGED -->
  <div class="how-section">
    <h2>How to Tell If Your Headphones Are Damaged</h2>
    <p>Run the frequency sweep and listen on each side, then compare against this table:</p>
    <table class="data-table">
      <thead><tr><th>Symptom</th><th>What it means</th></tr></thead>
      <tbody>
        <tr><td>One ear completely silent</td><td>Driver dead or cable open circuit</td></tr>
        <tr><td>Buzzing at all frequencies on one side</td><td>Debris in driver cavity — clean first</td></tr>
        <tr><td>Crackling at any volume level</td><td>Driver damage</td></tr>
        <tr><td>Treble cuts off on one side</td><td>Driver degradation on that ear</td></tr>
        <tr><td>Bass absent despite correct fit and seal</td><td>Driver or port problem</td></tr>
        <tr><td>Distortion only on one side</td><td>That driver is damaged</td></tr>
        <tr><td>Both ears sound identical but thin</td><td>Not damage — that is the headphone's tuning</td></tr>
      </tbody>
    </table>

    <p><strong>The one-ear swap test:</strong> Put the right cup on your left ear. If the problem moves with the cup, the driver is the issue. If the same ear has the problem regardless of which cup is on it, it is your ear canal, not the headphone.</p>
  </div>

  <!-- FAQ -->
  <div class="faq-section">
    <h2>Frequently asked questions</h2>

    <div class="faq-item">
      <p class="faq-q">How do I test my headphones online?</p>
      <p class="faq-a">Click "Left ear" to confirm sound in your left ear, "Right ear" for your right ear. Run the frequency sweep to check full-range driver response. Under three minutes total.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">Why is one earbud quieter than the other?</p>
      <p class="faq-a">Clean the mesh with a dry brush first — earwax blockage is the most common cause. If cleaning does not help, check the OS balance setting. If balance is centred and one driver is still quieter, the driver has degraded.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">How do I fix reversed headphone channels?</p>
      <p class="faq-a">Wired: replace the cable. Bluetooth: update firmware, then factory reset. USB headset: check companion app for a channel remap setting. Windows: disable Spatial Sound by right-clicking the speaker icon.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">Can I test AirPods with this tool?</p>
      <p class="faq-a">Yes. Open this page in Safari with AirPods connected. Run the left/right test. If channels are reversed, re-insert the buds and check Settings → Accessibility → Audio/Visual → Balance.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">What is driver mismatch?</p>
      <p class="faq-a">One driver produces more volume than the other at the same input. Even a 1 dB difference is audible in headphones as the stereo image pulling to one side.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">How do I test a gaming headset?</p>
      <p class="faq-a">Disable virtual surround first: in Windows, right-click the speaker icon → Spatial sound → Off. Disable surround in the companion app. Run the channel test — if channels are correct with surround off, the hardware is fine.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">Why does one earbud only work when I push the jack in further?</p>
      <p class="faq-a">The 3.5mm socket's spring contacts are worn. If pushing the jack fully in fixes it temporarily, the cable or socket needs replacement.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">Does this test work with Bluetooth headphones?</p>
      <p class="faq-a">Yes. Bluetooth latency causes the tone to play slightly late, but channel and frequency accuracy are unaffected. For latency testing, use the <a href="/bluetooth-latency-test/">Bluetooth Latency Test</a>.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">What does the frequency sweep test?</p>
      <p class="faq-a">It plays tones from 20Hz to 20kHz over 20 seconds. Any frequency range that sounds absent, distorted, or unequal between ears identifies a driver problem.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">How do I fix audio only playing in one ear on Windows?</p>
      <p class="faq-a">Three checks: (1) Settings → Accessibility → Audio → Mono Audio is OFF. (2) Settings → System → Sound → device Properties → Balance is centred. (3) Correct output device is selected.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">Why do my headphones sound fine with music but show a problem in the test?</p>
      <p class="faq-a">Music masks small imbalances. Test tones expose them because there is nothing to mask them. A problem the test reveals is real — it is just harder to notice during normal listening.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">Do open-back headphones test differently?</p>
      <p class="faq-a">The channel test is identical. The frequency sweep will show bass rolloff below 80–100Hz in open-back models — that is by design, not damage.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">How can I tell if my headphones are dying?</p>
      <p class="faq-a">Distortion at moderate volume on one driver, treble rolling off on one side, or bass disappearing despite correct fit. If the problem is on one driver only and started recently, that driver is failing.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">My Bluetooth headphones sound worse than wired. Is that normal?</p>
      <p class="faq-a">Yes, if SBC codec is active. SBC compresses aggressively. If your headphones support AAC, aptX, or LDAC and your source supports the same codec, switching to it improves quality significantly.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">What is the one-ear swap test?</p>
      <p class="faq-a">Put the right cup on your left ear. If the problem moves with the cup, the driver is the issue. If the same ear has the problem regardless of which cup, it is your ear canal, not the headphone.</p>
    </div>

    <p class="conclusion-text">Run the left/right test every time you connect a new pair. Run the frequency sweep when one ear sounds different from the other. The whole test takes under three minutes. For testing desktop speakers or soundbar channels, see the <a href="/speaker-test/">Left Right Speaker Test</a>. For measuring audio delay, use the <a href="/latency-test/">Audio Latency Test</a>.</p>
  </div>

</Layout>

<script>
  (() => {
    let audioCtx: AudioContext | null = null;
    let activeNodes: { osc?: OscillatorNode; gain: GainNode; buf?: AudioBufferSourceNode }[] = [];
    let currentFreq: number | 'pink' | 'sweep' = 'pink';
    let volume = 0.6;
    let isPlaying = false;
    let currentChannel: 'left' | 'right' | 'both' | null = null;
    let sweepRafId: number | null = null;
    let sweepStartCtxTime: number | null = null;
    const SWEEP_DURATION = 20;

    const statusDot  = document.getElementById('hp-dot')!;
    const statusText = document.getElementById('hp-status')!;
    const resultNote = document.getElementById('hp-result')!;
    const btnLeft    = document.getElementById('hp-btn-left') as HTMLButtonElement;
    const btnRight   = document.getElementById('hp-btn-right') as HTMLButtonElement;
    const btnBoth    = document.getElementById('hp-btn-both') as HTMLButtonElement;
    const volSlider  = document.getElementById('hp-vol') as HTMLInputElement;
    const volPct     = document.getElementById('hp-vol-pct')!;
    const earLeft    = document.getElementById('ear-left')!;
    const earRight   = document.getElementById('ear-right')!;
    const pulseLeft  = document.getElementById('hp-pulse-left')!;
    const pulseRight = document.getElementById('hp-pulse-right')!;
    const sweepHzEl  = document.getElementById('sweep-hz')!;

    function getCtx() {
      if (!audioCtx) audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      return audioCtx;
    }

    function makePinkNoise(ctx: AudioContext): AudioBuffer {
      const len = ctx.sampleRate * 2;
      const buf = ctx.createBuffer(1, len, ctx.sampleRate);
      const out = buf.getChannelData(0);
      let b0=0,b1=0,b2=0,b3=0,b4=0,b5=0,b6=0;
      for (let i = 0; i < len; i++) {
        const w = Math.random() * 2 - 1;
        b0=0.99886*b0+w*0.0555179; b1=0.99332*b1+w*0.0750759;
        b2=0.96900*b2+w*0.1538520; b3=0.86650*b3+w*0.3104856;
        b4=0.55000*b4+w*0.5329522; b5=-0.7616*b5-w*0.0168980;
        out[i]=(b0+b1+b2+b3+b4+b5+b6+w*0.5362)/7; b6=w*0.115926;
      }
      return buf;
    }

    function updateBothLabel() {
      if (isPlaying) {
        btnBoth.innerHTML = `<svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true"><rect x="1.5" y="1.5" width="8" height="8" rx="1.5" fill="currentColor"/></svg> Stop`;
      } else if (currentFreq === 'sweep') {
        btnBoth.innerHTML = `<svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true"><path d="M2.5 1.5l7 4-7 4V1.5z" fill="currentColor"/></svg> Start Sweep`;
      } else {
        btnBoth.innerHTML = `<svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true"><path d="M2.5 1.5l7 4-7 4V1.5z" fill="currentColor"/></svg> Run Test`;
      }
    }

    function setVisualPlaying(channel: 'left' | 'right' | 'both') {
      earLeft.classList.toggle('active',  channel === 'left'  || channel === 'both');
      earRight.classList.toggle('active', channel === 'right' || channel === 'both');
      pulseLeft.classList.toggle('pulsing',  channel === 'left'  || channel === 'both');
      pulseRight.classList.toggle('pulsing', channel === 'right' || channel === 'both');
      statusDot.className = 'dot active';
    }

    function setVisualStopped() {
      earLeft.classList.remove('active');
      earRight.classList.remove('active');
      pulseLeft.classList.remove('pulsing');
      pulseRight.classList.remove('pulsing');
      statusDot.className = 'dot';
      sweepHzEl.textContent = '';
    }

    function updateSweepDisplay() {
      if (sweepStartCtxTime === null || !audioCtx) return;
      const elapsed = audioCtx.currentTime - sweepStartCtxTime;
      const ratio = Math.min(elapsed / SWEEP_DURATION, 1);
      const hz = 20 * Math.pow(1000, ratio);
      const hzStr = hz < 1000
        ? `${Math.round(hz)} Hz`
        : `${(hz / 1000).toFixed(hz < 5000 ? 1 : 0)} kHz`;
      statusText.textContent = hzStr;
      sweepHzEl.textContent = hzStr;

      if (ratio >= 1) {
        sweepRafId = null;
        sweepStartCtxTime = null;
        isPlaying = false;
        currentChannel = null;
        setVisualStopped();
        statusText.textContent = 'Sweep complete';
        resultNote.textContent = 'Sweep complete — compare how each driver responded. If one ear dropped out at any frequency, that driver is failing.';
        resultNote.className = 'result-note success';
        updateBothLabel();
        try { activeNodes.forEach(({ gain }) => gain.disconnect()); } catch {}
        activeNodes = [];
      } else {
        sweepRafId = requestAnimationFrame(updateSweepDisplay);
      }
    }

    function stopAll() {
      if (sweepRafId !== null) {
        cancelAnimationFrame(sweepRafId);
        sweepRafId = null;
      }
      sweepStartCtxTime = null;

      const ctx = getCtx();
      activeNodes.forEach(({ gain, osc, buf }) => {
        try { gain.gain.setTargetAtTime(0, ctx.currentTime, 0.04); } catch {}
        try { osc?.stop(ctx.currentTime + 0.1); } catch {}
        try { buf?.stop(ctx.currentTime + 0.1); } catch {}
      });
      activeNodes = [];
      isPlaying = false;
      currentChannel = null;
      setVisualStopped();
    }

    function play(channel: 'left' | 'right' | 'both') {
      stopAll();
      const ctx = getCtx();
      if (ctx.state === 'suspended') ctx.resume();

      const gain   = ctx.createGain();
      const panner = ctx.createStereoPanner();
      gain.connect(panner);
      panner.connect(ctx.destination);
      gain.gain.setValueAtTime(0, ctx.currentTime);
      gain.gain.linearRampToValueAtTime(volume, ctx.currentTime + 0.08);
      panner.pan.value = channel === 'left' ? -1 : channel === 'right' ? 1 : 0;

      if (currentFreq === 'pink') {
        const src = ctx.createBufferSource();
        src.buffer = makePinkNoise(ctx);
        src.loop = true;
        src.connect(gain);
        src.start();
        activeNodes.push({ gain, buf: src });
      } else if (currentFreq === 'sweep') {
        const osc = ctx.createOscillator();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(20, ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(20000, ctx.currentTime + SWEEP_DURATION);
        osc.connect(gain);
        sweepStartCtxTime = ctx.currentTime;
        osc.start();
        osc.stop(ctx.currentTime + SWEEP_DURATION);
        activeNodes.push({ gain, osc });
        sweepRafId = requestAnimationFrame(updateSweepDisplay);
      } else {
        const osc = ctx.createOscillator();
        osc.type = 'sine';
        osc.frequency.value = currentFreq as number;
        osc.connect(gain);
        osc.start();
        activeNodes.push({ gain, osc });
      }

      isPlaying = true;
      currentChannel = channel;
      setVisualPlaying(channel);
      updateBothLabel();

      if (currentFreq === 'sweep') {
        statusText.textContent = '20 Hz';
        sweepHzEl.textContent = '20 Hz';
        if (channel === 'both') {
          resultNote.textContent = 'Sweeping 20 Hz → 20 kHz on both ears. Listen for drops or distortion on one side.';
        } else {
          resultNote.textContent = `Sweeping 20 Hz → 20 kHz on ${channel} ear.`;
        }
      } else {
        const freqLabel = currentFreq === 'pink' ? 'pink noise' : `${currentFreq} Hz`;
        if (channel === 'both') {
          statusText.textContent = `Playing — both ears`;
          resultNote.textContent = `Both ears should sound equally loud and tonal playing ${freqLabel}.`;
        } else {
          statusText.textContent = `Playing — ${channel} ear`;
          resultNote.textContent = `Sound should come from your ${channel.toUpperCase()} ear only.`;
        }
      }
      resultNote.className = 'result-note success';
    }

    function stop() {
      stopAll();
      statusText.textContent = 'Ready to test';
      resultNote.textContent = 'Select a signal and a channel to begin.';
      resultNote.className = 'result-note';
      updateBothLabel();
    }

    btnLeft.addEventListener('click',  () => { if (isPlaying && currentChannel === 'left')  { stop(); return; } play('left'); });
    btnRight.addEventListener('click', () => { if (isPlaying && currentChannel === 'right') { stop(); return; } play('right'); });
    btnBoth.addEventListener('click',  () => { if (isPlaying) { stop(); return; } play('both'); });

    volSlider.addEventListener('input', () => {
      volume = Number(volSlider.value) / 100;
      volPct.textContent = volSlider.value;
      if (isPlaying && currentFreq !== 'sweep') {
        activeNodes.forEach(({ gain }) => { try { gain.gain.value = volume; } catch {} });
      }
    });

    document.querySelectorAll('.freq-chip').forEach(chip => {
      chip.addEventListener('click', (e) => {
        document.querySelectorAll('.freq-chip').forEach(c => c.classList.remove('active'));
        (e.currentTarget as HTMLElement).classList.add('active');
        const f = (e.currentTarget as HTMLElement).dataset.freq!;
        currentFreq = f === 'pink' ? 'pink' : f === 'sweep' ? 'sweep' : Number(f);
        updateBothLabel();
        if (isPlaying && currentChannel) play(currentChannel);
      });
    });
  })();
</script>

<style>
