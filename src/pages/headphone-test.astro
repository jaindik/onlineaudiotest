  }
  .freq-chip:hover { border-color: var(--hairline-strong); color: var(--ink); }
  .freq-chip.active { background: var(--invert-bg); color: var(--invert-fg); border-color: var(--invert-bg); }
  .chip-sub { font-size: 10px; opacity: .6; }
  .chip-badge {
    font-size: 10px;
