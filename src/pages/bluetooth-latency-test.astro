---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Bluetooth Latency Test",
      "url": "https://onlineaudiotest.com/bluetooth-latency-test/",
      "description": "Free Bluetooth latency test. Measure your Bluetooth headphone or speaker audio delay in milliseconds. Understand your codec and how to reduce wireless audio lag. No download.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "browserRequirements": "Requires Web Audio API support",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "provider": { "@type": "Organization", "name": "OnlineAudioTest.com", "url": "https://onlineaudiotest.com/" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://onlineaudiotest.com/" },
        { "@type": "ListItem", "position": 2, "name": "Latency Test", "item": "https://onlineaudiotest.com/latency-test/" },
        { "@type": "ListItem", "position": 3, "name": "Bluetooth Latency Test", "item": "https://onlineaudiotest.com/bluetooth-latency-test/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Which Bluetooth codec has the lowest latency?",
          "acceptedAnswer": { "@type": "Answer", "text": "aptX Low Latency achieves approximately 40 ms, the lowest of the widely supported codecs. LC3 (Bluetooth LE Audio) targets around 20–40 ms. For comparison: SBC (the universal fallback) is typically 150–250 ms; AAC is typically 120–200 ms; standard aptX is typically 100–200 ms. LDAC is primarily a high-quality codec, not a low-latency one — its latency is in the 150–200 ms range, similar to SBC. Both your phone and headphones must support the same codec for it to be used." }
        },
        {
          "@type": "Question",
          "name": "How do I reduce Bluetooth audio delay on Android?",
          "acceptedAnswer": { "@type": "Answer", "text": "Enable Developer Options on Android (Settings → About Phone → tap Build Number 7 times), then go to Developer Options → Bluetooth Audio Codec and select aptX, aptX HD, or LDAC if available. Avoid SBC unless forced. After changing, disconnect and reconnect your headphones. Re-run this test to confirm the new latency. Note that the codec must be supported by both your phone and headphones." }
        },
        {
          "@type": "Question",
          "name": "Does Bluetooth 5.0 reduce audio latency?",
          "acceptedAnswer": { "@type": "Answer", "text": "Bluetooth 5.0 increases range and bandwidth over Bluetooth 4.2, but it does not inherently reduce audio latency. Latency is determined by the codec, not the Bluetooth version. A device using Bluetooth 5.0 with the SBC codec will still have 150–250 ms of delay. Latency improvements come from upgrading the codec (aptX LL, LC3) or using 2.4 GHz wireless (not standard Bluetooth), as found in many gaming headsets." }
        },
        {
          "@type": "Question",
          "name": "My gaming headset has a 'Game Mode' — will it reduce Bluetooth latency?",
          "acceptedAnswer": { "@type": "Answer", "text": "Many gaming headsets implement 'Game Mode' as a low-latency preset that switches to aptX Low Latency or a proprietary protocol on the Bluetooth connection. This can bring latency down to 40–60 ms, a noticeable improvement over standard SBC. However, some headsets that advertise low gaming latency use a 2.4 GHz USB dongle instead of Bluetooth, which is a different radio technology and can achieve under 20 ms. Check your headset's documentation to confirm which mode uses which connection type." }
        },
        {
          "@type": "Question",
          "name": "Why is Bluetooth audio delayed on iPhone?",
          "acceptedAnswer": { "@type": "Answer", "text": "iPhone supports AAC for Bluetooth audio, which typically delivers 120–200 ms of latency with Apple and compatible devices. iOS does not expose codec selection — it negotiates AAC automatically with supported headphones, falling back to SBC otherwise. Unlike Android, you cannot manually select a codec on iPhone. If you need lower latency on iPhone, use wired audio via a Lightning or USB-C adapter, or use AirPods which are optimized for Apple's AAC implementation." }
        }
      ]
    }
  ]
};
---

<Layout
  title="Bluetooth Latency Test — Measure Wireless Audio Delay in ms"
  description="Measure your Bluetooth headphone or speaker delay in milliseconds. See whether you're using SBC, AAC, aptX, or LDAC — and how much latency each adds. Free, instant, no download."
  keywords="bluetooth latency test, bluetooth audio delay, wireless audio latency, bluetooth headphone latency, bluetooth 5.0 latency test, bluetooth audio lag test, aptx latency test, sbc latency test"
  canonical="https://onlineaudiotest.com/bluetooth-latency-test/"
  schema={schema}
  sidebar={true}
>

  <!-- HERO -->
  <section class="tool-hero container">
    <h1>Bluetooth Latency Test</h1>
    <p>Connect your Bluetooth headphones or speaker, then run the test. The result shows how much audio delay your Bluetooth device introduces — determined primarily by which codec is active between your device and headphones.</p>
  </section>

  <!-- TOOL -->
  <div class="tool-card-wrap">
    <div class="tool-card" id="latency-tool">

      <div class="status-bar">
        <div class="status-pill">
          <span class="dot" id="status-dot"></span>
          <span id="status-text">Connect Bluetooth device, then measure</span>
        </div>
        <span class="eyebrow caption-mono" id="phase-label"></span>
      </div>

      <div class="result-panel" id="result-panel" hidden>
        <div class="latency-display">
          <span class="latency-num" id="latency-num">-</span>
          <span class="latency-unit">ms</span>
        </div>
        <div class="grade-badge" id="grade-badge"></div>
        <div class="latency-breakdown" id="latency-breakdown" hidden>
          <span class="breakdown-item">Base <strong id="base-ms">-</strong> ms</span>
          <span class="breakdown-sep">·</span>
          <span class="breakdown-item">Output <strong id="output-ms">-</strong> ms</span>
        </div>
        <p class="latency-advice" id="latency-advice"></p>
      </div>

      <div class="action-row">
        <button class="btn btn-primary btn-lg" id="btn-measure" style="min-width:200px">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.4"/>
            <path d="M7 4v3.2l2 1.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Test Bluetooth Latency
        </button>
        <button class="btn btn-secondary btn-sm" id="btn-roundtrip">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <rect x="4.5" y="1" width="3" height="6" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M2.5 6a3.5 3.5 0 007 0" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            <line x1="6" y1="9.5" x2="6" y2="11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          Round-Trip Test (mic)
        </button>
      </div>

      <p class="result-note" id="result-note">Make sure your Bluetooth device is set as your output before measuring.</p>
    </div>
  </div>

  <!-- CODEC COMPARISON -->
  <div class="how-section">
    <h2>Bluetooth codec latency comparison</h2>
    <p style="font-size:14px;color:var(--mute);margin-bottom:var(--s-md)">The codec active between your phone and headphones is the single biggest factor in Bluetooth audio latency. Both devices must support the same codec for it to be used — otherwise the connection falls back to SBC.</p>
    <div class="codec-table">
      <div class="codec-row codec-header">
        <span>Codec</span>
        <span>Typical Latency</span>
        <span>Common Devices</span>
      </div>
      <div class="codec-row">
        <span><strong>SBC</strong></span>
        <span class="latency-poor">150–250 ms</span>
        <span>All Bluetooth devices (universal fallback)</span>
      </div>
      <div class="codec-row">
        <span><strong>AAC</strong></span>
        <span class="latency-fair">80–180 ms</span>
        <span>iPhone, AirPods, many Android phones</span>
      </div>
      <div class="codec-row">
        <span><strong>aptX</strong></span>
        <span class="latency-fair">70–120 ms</span>
        <span>Android phones, Qualcomm-based headsets</span>
      </div>
      <div class="codec-row">
        <span><strong>aptX Low Latency</strong></span>
        <span class="latency-good">32–40 ms</span>
        <span>Select Qualcomm headsets + phones</span>
      </div>
      <div class="codec-row">
        <span><strong>LDAC</strong></span>
        <span class="latency-fair">80–150 ms</span>
        <span>Sony headphones, Android 8+</span>
      </div>
      <div class="codec-row">
        <span><strong>LC3 (LE Audio)</strong></span>
        <span class="latency-good">20–50 ms</span>
        <span>Bluetooth 5.2+ devices (2023 onward)</span>
      </div>
    </div>
  </div>

  <!-- WHAT YOUR RESULT MEANS -->
  <div class="how-section">
    <h2>What your Bluetooth latency result means</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <p class="step-body"><strong>Under 40 ms</strong> — Excellent. You're likely on aptX Low Latency, LC3 (LE Audio), or the device is actually wired. Fine for any use including gaming and live monitoring.</p>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <p class="step-body"><strong>40–120 ms</strong> — Good Bluetooth. Consistent with aptX, AAC, or a well-optimised connection. Imperceptible for streaming and calls. May be noticeable in competitive gaming or rhythm games.</p>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <p class="step-body"><strong>120–200 ms</strong> — Standard Bluetooth. Typical for SBC or AAC in a congested RF environment. Suitable for music and calls; avoid for gaming or latency-sensitive tasks.</p>
      </div>
      <div class="step">
        <span class="step-num">4</span>
        <p class="step-body"><strong>Over 200 ms</strong> — High delay. You're on SBC codec or there is significant Bluetooth interference. Switch to a higher-quality codec in Android Developer Options, or move closer to the paired device and away from Wi-Fi routers.</p>
      </div>
    </div>
  </div>

  <!-- HOW TO CHECK CODEC ON ANDROID -->
  <div class="how-section">
    <h2>How to check and change your Bluetooth codec (Android)</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <p class="step-body"><strong>Enable Developer Options.</strong> Go to Settings → About Phone → tap Build Number seven times. You'll see a confirmation that Developer Options is now enabled.</p>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <p class="step-body"><strong>Open Developer Options.</strong> Go back to Settings → System → Developer Options (location varies by manufacturer). Scroll down to find "Bluetooth Audio Codec".</p>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <p class="step-body"><strong>Select the best codec your headphones support.</strong> Choose aptX HD, LDAC, or aptX if available. Avoid SBC unless forced. If your headphones don't support the selected codec, the connection automatically falls back to SBC.</p>
      </div>
      <div class="step">
        <span class="step-num">4</span>
        <p class="step-body"><strong>Disconnect and reconnect your headphones</strong>, then re-run this test to confirm the latency has changed. A successful codec upgrade typically reduces latency by 50–100 ms.</p>
      </div>
    </div>
    <p style="font-size:13px;color:var(--mute);margin-top:var(--s-md)">Note: iPhone does not expose codec selection. iOS negotiates AAC automatically with compatible devices and falls back to SBC otherwise.</p>
  </div>

  <!-- GAMING HEADSETS -->
  <div class="how-section">
    <h2>Gaming headsets and Bluetooth latency</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">!</span>
        <p class="step-body"><strong>Standard Bluetooth is not designed for gaming.</strong> Even at best (aptX LL ~40 ms), Bluetooth latency is perceptible during competitive play. Many "gaming" headsets that use standard Bluetooth simply cannot achieve the latency of a wired connection.</p>
      </div>
      <div class="step">
        <span class="step-num">✓</span>
        <p class="step-body"><strong>Gaming headsets with 2.4 GHz dongles are different.</strong> USB dongle-based wireless headsets (common from brands like SteelSeries, Logitech, Razer, HyperX) use proprietary 2.4 GHz wireless — not standard Bluetooth — and achieve under 20 ms latency. This test will show the latency of your default audio output. If using a USB dongle, connect it and select it as your output before testing.</p>
      </div>
      <div class="step">
        <span class="step-num">~</span>
        <p class="step-body"><strong>"Game Mode" on Bluetooth headsets.</strong> Some headsets switch to aptX Low Latency in Game Mode, achieving ~40 ms. This is better than standard Bluetooth but still higher than a 2.4 GHz dongle or wired connection. Check your headset manual to see which radio technology Game Mode uses.</p>
      </div>
    </div>
  </div>

  <!-- RELATED TESTS -->
  <div class="how-section">
    <h2>Related latency tests</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">→</span>
        <p class="step-body"><a href="/latency-test/"><strong>General Audio Latency Test</strong></a> — Measures system output delay for any audio device. Use this as a baseline before and after changing your Bluetooth codec settings.</p>
      </div>
      <div class="step">
        <span class="step-num">→</span>
        <p class="step-body"><a href="/airpods-latency-test/"><strong>AirPods Latency Test</strong></a> — Specific guidance for AirPods, AirPods Pro, and AirPods Max. Covers the SCO codec issue that spikes latency when AirPods are used as a microphone on Mac.</p>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="faq-section">
    <h2>Frequently asked questions</h2>
    <div class="faq-item">
      <p class="faq-q">Which Bluetooth codec has the lowest latency?</p>
      <p class="faq-a">aptX Low Latency achieves approximately 32–40 ms, the lowest of the widely supported codecs. LC3 (Bluetooth LE Audio) targets 20–50 ms with better efficiency. For comparison: AAC is typically 80–180 ms, aptX is 70–120 ms, LDAC is 80–150 ms, and SBC (the universal fallback) is 150–250 ms. Both your phone and headphones must support the same codec for it to activate.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">How do I reduce Bluetooth audio delay on Android?</p>
      <p class="faq-a">Enable Developer Options (Settings → About Phone → tap Build Number 7 times), then go to Developer Options → Bluetooth Audio Codec and select aptX, aptX HD, or LDAC if available. Disconnect and reconnect your headphones after changing. Re-run this test to confirm the improvement. Note that both your phone and headphones must support the selected codec.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">Does Bluetooth 5.0 reduce audio latency?</p>
      <p class="faq-a">No — Bluetooth 5.0 increases range and bandwidth over Bluetooth 4.2, but audio latency is determined by the codec, not the Bluetooth version. A Bluetooth 5.0 device using SBC still has 150–250 ms of delay. Latency improvements come from upgrading the codec (aptX LL, LC3) or switching to 2.4 GHz wireless instead of standard Bluetooth.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">My gaming headset has a 'Game Mode' — will it reduce Bluetooth latency?</p>
      <p class="faq-a">Many gaming headsets implement Game Mode as a lower-latency setting that switches to aptX Low Latency or a proprietary protocol. This can bring latency down to 40–60 ms. However, some headsets advertised as "low latency for gaming" use a 2.4 GHz USB dongle — not standard Bluetooth — which achieves under 20 ms. Check your headset's documentation to confirm which mode uses which connection type.</p>
    </div>
    <div class="faq-item">
      <p class="faq-q">Why is Bluetooth audio delayed on iPhone?</p>
      <p class="faq-a">iPhone supports AAC for Bluetooth audio, which delivers 80–180 ms with compatible devices. iOS does not expose codec selection — it negotiates automatically, falling back to SBC with incompatible headphones. Unlike Android, you cannot manually override the codec on iPhone. For lower latency on iPhone, use a wired connection via a USB-C or Lightning adapter.</p>
    </div>
  </div>

</Layout>

<script>
  (() => {
    type Phase = 'idle' | 'measuring' | 'result' | 'rt-requesting' | 'rt-running' | 'rt-result';

    let phase: Phase = 'idle';
    let audioCtx: AudioContext | null = null;

    const btnMeasure   = document.getElementById('btn-measure') as HTMLButtonElement;
    const btnRoundtrip = document.getElementById('btn-roundtrip') as HTMLButtonElement;
    const statusDot    = document.getElementById('status-dot')!;
    const statusText   = document.getElementById('status-text')!;
    const phaseLabel   = document.getElementById('phase-label')!;
    const resultPanel  = document.getElementById('result-panel')!;
    const latencyNum   = document.getElementById('latency-num')!;
    const gradeBadge   = document.getElementById('grade-badge')!;
    const breakdown    = document.getElementById('latency-breakdown')!;
    const baseMs       = document.getElementById('base-ms')!;
    const outputMs     = document.getElementById('output-ms')!;
    const latencyAdvice = document.getElementById('latency-advice')!;
    const resultNote   = document.getElementById('result-note')!;

    function getCtx() {
      if (!audioCtx) audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      return audioCtx;
    }

    function setStatus(active: boolean, warning: boolean, text: string) {
      statusText.textContent = text;
      statusDot.className = 'dot' + (active ? ' active' : warning ? ' warning' : '');
    }

    function grade(ms: number): { label: string; cls: string; advice: string } {
      if (ms < 40) return {
        label: 'Excellent — low latency codec',
        cls: 'grade-excellent',
        advice: 'Very low Bluetooth latency. Likely on aptX Low Latency, LC3, or a 2.4 GHz wireless connection. Suitable for gaming and latency-sensitive audio.'
      };
      if (ms < 120) return {
        label: 'Good — aptX or AAC',
        cls: 'grade-good',
        advice: 'Good Bluetooth codec (aptX or AAC). Fine for music, streaming, and calls. May be noticeable in competitive gaming or rhythm games.'
      };
      if (ms < 200) return {
        label: 'Standard — SBC or AAC',
        cls: 'grade-fair',
        advice: 'Standard Bluetooth latency. Suitable for music and calls but avoid for gaming. On Android, try switching to aptX or LDAC in Developer Options.'
      };
      return {
        label: 'High — SBC fallback',
        cls: 'grade-poor',
        advice: 'High Bluetooth latency, consistent with SBC codec. On Android, enable Developer Options and switch to a higher-quality codec. Move closer to your device to reduce interference.'
      };
    }

    function showResult(ms: number, label: string, baseVal?: number, outputVal?: number) {
      const g = grade(ms);
      latencyNum.textContent = ms < 1 ? '<1' : ms.toFixed(ms < 10 ? 1 : 0);
      gradeBadge.textContent = g.label;
      gradeBadge.className = 'grade-badge ' + g.cls;
      latencyAdvice.textContent = g.advice;
      phaseLabel.textContent = label;

      if (baseVal !== undefined && outputVal !== undefined) {
        baseMs.textContent = baseVal.toFixed(1);
        outputMs.textContent = outputVal.toFixed(1);
        breakdown.hidden = false;
      } else {
        breakdown.hidden = true;
      }

      resultPanel.hidden = false;
    }

    async function measureSystem() {
      phase = 'measuring';
      setStatus(true, false, 'Measuring Bluetooth latency…');
      btnMeasure.disabled = true;
      btnRoundtrip.disabled = true;
      resultNote.textContent = 'Initializing audio context…';

      const ctx = getCtx();
      if (ctx.state === 'suspended') await ctx.resume();

      const warmup = ctx.createBuffer(1, ctx.sampleRate * 0.1, ctx.sampleRate);
      const src = ctx.createBufferSource();
      src.buffer = warmup;
      src.connect(ctx.destination);
      src.start();

      await new Promise<void>(r => setTimeout(r, 150));

      const base   = (ctx.baseLatency   ?? 0) * 1000;
      const output = (ctx.outputLatency ?? 0) * 1000;
      const total  = base + output;

      phase = 'result';
      setStatus(false, false, 'Measurement complete');

      if (total < 0.5) {
        showResult(0, 'Bluetooth latency');
        resultNote.textContent = 'Your browser does not expose latency values. Use the Round-Trip Test for a direct measurement.';
        resultNote.className = 'result-note';
      } else {
        showResult(total, 'Bluetooth latency', base, output);
        resultNote.textContent = 'Latency measured. Confirm your Bluetooth device is the active output.';
        resultNote.className = 'result-note success';
      }

      btnMeasure.textContent = 'Measure Again';
      btnMeasure.disabled = false;
      btnRoundtrip.disabled = false;
    }

    async function runRoundTrip() {
      phase = 'rt-requesting';
      setStatus(false, true, 'Requesting mic…');
      btnMeasure.disabled = true;
      btnRoundtrip.disabled = true;
      resultNote.textContent = 'Allow microphone access to run the round-trip test.';
      resultNote.className = 'result-note';

      let stream: MediaStream;
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          audio: { echoCancellation: false, noiseSuppression: false, autoGainControl: false }
        });
      } catch {
        setStatus(false, false, 'Mic access denied');
        resultNote.textContent = 'Microphone access is required for the round-trip test.';
        resultNote.className = 'result-note error';
        btnMeasure.disabled = false;
        btnRoundtrip.disabled = false;
        phase = 'result';
        return;
      }

      phase = 'rt-running';
      setStatus(true, false, 'Running round-trip test…');
      resultNote.textContent = 'Keep your microphone near your Bluetooth speakers or headphones. Running test…';

      const ctx = getCtx();
      if (ctx.state === 'suspended') await ctx.resume();

      const micSrc  = ctx.createMediaStreamSource(stream);
      const analyser = ctx.createAnalyser();
      analyser.fftSize = 256;
      micSrc.connect(analyser);

      const baseline = await measureBaseline(analyser, 400);

      const clickDelay = 0.3;
      const clickAt = ctx.currentTime + clickDelay;
      playImpulse(ctx, clickAt, 0.85);
      const clickWallMs = Date.now() + clickDelay * 1000;

      const latencyMs = await detectImpulse(analyser, baseline, clickWallMs);

      stream.getTracks().forEach(t => t.stop());
      micSrc.disconnect();

      phase = 'rt-result';
      setStatus(false, false, 'Test complete');

      if (latencyMs === null) {
        resultNote.textContent = 'Could not detect the test click. Make sure your speakers are audible and try in a quieter environment.';
        resultNote.className = 'result-note error';
      } else {
        showResult(latencyMs, 'Round-trip latency');
        resultNote.textContent = 'Round-trip latency measured. Includes speaker → air → mic delay.';
        resultNote.className = 'result-note success';
      }

      btnMeasure.disabled = false;
      btnRoundtrip.disabled = false;
    }

    function measureBaseline(analyser: AnalyserNode, durationMs: number): Promise<number> {
      return new Promise(resolve => {
        const buf = new Uint8Array(analyser.frequencyBinCount);
        let sum = 0, count = 0;
        const start = Date.now();
        const tick = () => {
          analyser.getByteTimeDomainData(buf);
          let s = 0;
          for (let i = 0; i < buf.length; i++) s += ((buf[i] / 128) - 1) ** 2;
          sum += Math.sqrt(s / buf.length);
          count++;
          if (Date.now() - start < durationMs) requestAnimationFrame(tick);
          else resolve(count > 0 ? sum / count : 0);
        };
        tick();
      });
    }

    function playImpulse(ctx: AudioContext, when: number, gain: number) {
      const duration = 0.01;
      const buf = ctx.createBuffer(1, Math.floor(ctx.sampleRate * duration), ctx.sampleRate);
      const data = buf.getChannelData(0);
      for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1);

      const gainNode = ctx.createGain();
      gainNode.gain.value = gain;
      gainNode.connect(ctx.destination);

      const src = ctx.createBufferSource();
      src.buffer = buf;
      src.connect(gainNode);
      src.start(when);
    }

    function detectImpulse(analyser: AnalyserNode, baseline: number, clickWallMs: number): Promise<number | null> {
      return new Promise(resolve => {
        const threshold = Math.max(baseline * 3.5, 0.05);
        const buf = new Uint8Array(analyser.frequencyBinCount);
        const giveUpAt = clickWallMs + 3000;

        const poll = () => {
          const now = Date.now();
          if (now > giveUpAt) { resolve(null); return; }

          analyser.getByteTimeDomainData(buf);
          let s = 0;
          for (let i = 0; i < buf.length; i++) s += ((buf[i] / 128) - 1) ** 2;
          const rms = Math.sqrt(s / buf.length);

          if (now >= clickWallMs && rms > threshold) {
            resolve(now - clickWallMs);
            return;
          }

          setTimeout(poll, 4);
        };

        const waitMs = Math.max(0, clickWallMs - Date.now() - 50);
        setTimeout(poll, waitMs);
      });
    }

    btnMeasure.addEventListener('click', measureSystem);
    btnRoundtrip.addEventListener('click', runRoundTrip);
  })();
</script>

<style>
  .result-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-sm);
    padding: var(--s-lg) 0;
  }

  .latency-display {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .latency-num {
    font-family: var(--font-mono);
    font-size: 64px;
    font-weight: 700;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -2px;
