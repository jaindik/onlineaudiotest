    text-decoration: none;
    transition: color .15s;
  }
  .tone-link-a:hover { color: var(--link); }
  .tone-link-a strong { color: var(--ink); font-weight: 500; }

  /* ── Peak table ────────────────── */
  .peak-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--s-xs);
  }
  .peak-label { display: block; }
