    text-align: left;
    padding: 4px 12px 4px 0;
    border-bottom: 1px solid var(--hairline);
  }
  .peak-table th:first-child { width: 28px; }
  .peak-table td {
    padding: 7px 12px 7px 0;
    border-bottom: 1px solid var(--hairline);
    color: var(--ink);
    vertical-align: middle;
  }
  .peak-table tr:last-child td { border-bottom: none; }
  .peak-rank { font-family: var(--font-mono); font-size: 11px; color: var(--mute); }
  .peak-freq-cell { font-family: var(--font-mono); font-weight: 500; }
  .peak-note-cell { font-family: var(--font-mono); color: var(--link); }
  .peak-row-empty td { color: var(--mute); }

  /* ── Permission card ───────────── */
  .perm-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-md);
