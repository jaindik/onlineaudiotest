  .freq-range-table-wrap { overflow-x: auto; }
  .freq-range-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .freq-range-table th {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--mute);
    font-weight: 400;
    text-align: left;
    padding: 6px 16px 6px 0;
    border-bottom: 1px solid var(--hairline);
  }
  .freq-range-table td {
    padding: 8px 16px 8px 0;
    border-bottom: 1px solid var(--hairline);
    color: var(--body-text);
    line-height: 1.5;
    vertical-align: top;
  }
  .freq-range-table tr:last-child td { border-bottom: none; }
  .freq-range-table td:first-child { font-family: var(--font-mono); color: var(--ink); font-weight: 500; white-space: nowrap; }
  .freq-range-table td:nth-child(2) { color: var(--ink); white-space: nowrap; }

  .seo-list {
    list-style: none; padding: 0;
    display: flex; flex-direction: column; gap: var(--s-sm);
  }
  .seo-list li {
    font-size: 14px; color: var(--body-text); line-height: 1.6;
    padding-left: var(--s-lg); position: relative;
  }
  .seo-list li::before { content: '–'; position: absolute; left: 0; color: var(--mute); }
  .seo-list strong { color: var(--ink); font-weight: 500; }
  .seo-list a { color: var(--link); text-decoration: underline; text-underline-offset: 2px; }

  /* ── Responsive ────────────────── */
  @media (max-width: 480px) {
    .stat-value { font-size: 15px; }
    .stats-row  { padding: var(--s-sm); gap: 0; }
    .cursor-tip { font-size: 10px; padding: 5px 8px; }
  }

  /* ── Reduced motion ─────────────── */
  @media (prefers-reduced-motion: reduce) {
    .cursor-line { transition: none; }
    .cursor-tip  { transition: none; }
