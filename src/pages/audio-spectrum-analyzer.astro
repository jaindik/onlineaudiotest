    color: var(--ink);
  }
  .perm-text { font-size: 14px; color: var(--body-text); line-height: 1.6; max-width: 380px; }
  .perm-text strong { color: var(--ink); font-weight: 500; }

  /* ── Outline button variant ────── */
  .btn-outline {
    background: transparent;
