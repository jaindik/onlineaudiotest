      "name": "OnlineAudioTest.com",
      "url": "https://onlineaudiotest.com/",
      "description": "Free browser-based audio test tools. Mic check online, left right audio test, stereo audio test, headphone test, and audio latency test — no download required.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://onlineaudiotest.com/{search_term_string}",
        "query-input": "required name=search_term_string"
