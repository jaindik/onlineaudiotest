        { "@type": "ListItem", "position": 9, "url": "https://onlineaudiotest.com/key-detector/",               "name": "Song Key Detector — Find the Musical Key of Any Song" },
        { "@type": "ListItem", "position": 10, "url": "https://onlineaudiotest.com/key-and-bpm-detector/",      "name": "Key and BPM Detector — Find Key and Tempo Together" }
