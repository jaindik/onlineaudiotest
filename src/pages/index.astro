};

const tools = [
  {
    href: '/mic-test/',
    eyebrow: 'Mic Check Online',
    title: 'Mic Test',
    desc: 'Mic check online in seconds. Detect your microphone, monitor real-time input levels, run an earphone mic test, and play back your recording instantly.',
    gradClass: 'develop',
    cta: 'Test my microphone →',
  },
  {
    href: '/speaker-test/',
    eyebrow: 'Left Right Audio Test',
    title: 'Speaker & Headphone Test',
    desc: 'Stereo audio test for speakers, headphones, and earphones. Left right audio test, headphone check, pink noise lossless audio test, and playback audio test.',
    gradClass: 'preview',
    cta: 'Run stereo test →',
  },
  {
    href: '/latency-test/',
    eyebrow: 'Bluetooth & System Delay',
    title: 'Latency Test',
    desc: 'Audio latency test in milliseconds. Measure Bluetooth audio delay, AirPods lag, Zoom sync issues, and gaming latency — instantly in your browser.',
    gradClass: 'ship',
    cta: 'Measure latency →',
  },
  {
    href: '/hearing-test/',
    eyebrow: 'Hearing Range & Age Test',
    title: 'Hearing Test',
    desc: 'Online hearing test that estimates the highest frequency you can hear and your hearing age. Pure tone sweep using the Web Audio API — no download required.',
    gradClass: 'develop',
    cta: 'Test my hearing →',
  },
  {
    href: '/audio-spectrum-analyzer/',
    eyebrow: 'Real-Time FFT Visualizer',
    title: 'Spectrum Analyzer',
    desc: 'See every frequency your microphone picks up in real time. FFT spectrum visualization with peak hold, dominant frequency display, and musical note detection.',
    gradClass: 'preview',
    cta: 'Open spectrum analyzer →',
  },
  {
    href: '/voice-recorder/',
    eyebrow: 'Browser Audio Recorder',
    title: 'Voice Recorder',
    desc: 'Record, pause, trim, normalize, and download audio in your browser. Live waveform, level meter, quality analytics, and WAV download — no uploads, no account.',
    gradClass: 'ship',
    cta: 'Start recording →',
  },
  {
    href: '/mic-quality-test/',
    eyebrow: 'Mic Diagnostic Report',
    title: 'Microphone Quality Test',
    desc: 'Speak for 10 seconds and get a full diagnostic: noise floor, signal-to-noise ratio, clipping count, dynamic range, and a quality score from 0–100 with personalized recommendations.',
    gradClass: 'develop',
    cta: 'Test mic quality →',
  },
  {
    href: '/bpm-detector/',
    eyebrow: 'Tempo Finder',
    title: 'BPM Detector',
    desc: 'Upload any MP3 or WAV and instantly detect the BPM of any song. Find the beats per minute for DJ mixing, music production, or workout playlists — no download required.',
    gradClass: 'preview',
