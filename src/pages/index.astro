    eyebrow: 'Musical Key Finder',
    title: 'Song Key Detector',
    desc: 'Upload any audio file and find its musical key and scale. Get the Camelot code for harmonic DJ mixing. Supports MP3, WAV, OGG, and FLAC — fully browser-based.',
    gradClass: 'ship',
    cta: 'Find the key →',
  },
  {
    href: '/key-and-bpm-detector/',
    eyebrow: 'DJ Analysis Tool',
